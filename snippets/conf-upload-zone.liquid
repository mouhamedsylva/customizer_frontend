{% comment %}
  Snippet pour la zone d'upload de fichiers
  Usage: {% render 'conf-upload-zone', id: 'front', label: 'Logo cœur', accept: 'image/*' %}
{% endcomment %}

{%- liquid
  assign id = id | default: 'upload'
  assign label = label | default: 'Choisir un fichier'
  assign accept = accept | default: 'image/*'
  assign max_size = max_size | default: '5MB'
  assign formats = formats | default: 'PNG, JPG, SVG'
  assign description = description | default: blank
  assign show_preview = show_preview | default: true
-%}

<div class="conf-upload-zone" data-upload-zone="{{ id }}">
  <input 
    type="file" 
    id="upload-{{ id }}" 
    class="conf-upload-input"
    data-upload="{{ id }}"
    accept="{{ accept }}"
    hidden
  >
  
  <label for="upload-{{ id }}" class="conf-upload-label" data-upload-label="{{ id }}">
    <div class="conf-upload-icon">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15V19C21 19.5304 20.7893 20.0391 20.4142 20.4142C20.0391 20.7893 19.5304 21 19 21H5C4.46957 21 3.96086 20.7893 3.58579 20.4142C3.21071 20.0391 3 19.5304 3 19V15"/>
        <polyline points="17 8 12 3 7 8"/>
        <line x1="12" y1="3" x2="12" y2="15"/>
      </svg>
    </div>
    
    <div class="conf-upload-content">
      <span class="conf-upload-title">{{ label }}</span>
      <span class="conf-upload-subtitle">Glissez-déposez ou cliquez pour parcourir</span>
      <span class="conf-upload-formats">{{ formats }} (max {{ max_size }})</span>
    </div>
    
    {%- if description != blank -%}
      <p class="conf-upload-description">{{ description }}</p>
    {%- endif -%}
  </label>
  
  <div class="conf-upload-dropzone" data-dropzone="{{ id }}" style="display: none;">
    <div class="conf-upload-dropzone-content">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
        <circle cx="8.5" cy="8.5" r="1.5"/>
        <polyline points="21 15 16 10 5 21"/>
      </svg>
      <p>Déposez votre fichier ici</p>
    </div>
  </div>
  
  {%- if show_preview -%}
    <div class="conf-upload-preview" data-preview="{{ id }}" style="display: none;">
      <div class="conf-upload-preview-image">
        <img src="" alt="Aperçu" data-preview-img="{{ id }}" width="100%" height="100%">
      </div>
      
      <div class="conf-upload-preview-info">
        <div class="conf-upload-preview-details">
          <span class="conf-upload-preview-name" data-preview-name="{{ id }}">fichier.jpg</span>
          <span class="conf-upload-preview-size" data-preview-size="{{ id }}">0 KB</span>
        </div>
        
        <div class="conf-upload-preview-actions">
          <button class="conf-upload-preview-btn conf-upload-edit-btn" data-upload-edit="{{ id }}" title="Modifier">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 3C17.2626 2.73735 17.5744 2.52901 17.9176 2.38687C18.2608 2.24473 18.6286 2.17157 19 2.17157C19.3714 2.17157 19.7392 2.24473 20.0824 2.38687C20.4256 2.52901 20.7374 2.73735 21 3C21.2626 3.26264 21.471 3.57444 21.6131 3.9176C21.7553 4.26077 21.8284 4.62856 21.8284 5C21.8284 5.37143 21.7553 5.73923 21.6131 6.08239C21.471 6.42555 21.2626 6.73735 21 7L7.5 20.5L2 22L3.5 16.5L17 3Z"/>
            </svg>
          </button>
          
          <button class="conf-upload-preview-btn conf-upload-remove-btn" data-upload-remove="{{ id }}" title="Supprimer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="3 6 5 6 21 6"/>
              <path d="M19 6V20C19 20.5304 18.7893 21.0391 18.4142 21.4142C18.0391 21.7893 17.5304 22 17 22H7C6.46957 22 5.96086 21.7893 5.58579 21.4142C5.21071 21.0391 5 20.5304 5 20V6M8 6V4C8 3.46957 8.21071 2.96086 8.58579 2.58579C8.96086 2.21071 9.46957 2 10 2H14C14.5304 2 15.0391 2.21071 15.4142 2.58579C15.7893 2.96086 16 3.46957 16 4V6"/>
            </svg>
          </button>
        </div>
      </div>
      
      <div class="conf-upload-progress" data-progress="{{ id }}" style="display: none;">
        <div class="conf-upload-progress-bar">
          <div class="conf-upload-progress-fill" data-progress-fill="{{ id }}" style="width: 0%;"></div>
        </div>
        <span class="conf-upload-progress-text" data-progress-text="{{ id }}">0%</span>
      </div>
    </div>
  {%- endif -%}
  
  <div class="conf-upload-error" data-error="{{ id }}" style="display: none;">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
      <path d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM13 17H11V15H13V17ZM13 13H11V7H13V13Z" fill="currentColor"/>
    </svg>
    <span data-error-message="{{ id }}">Une erreur est survenue</span>
  </div>
</div>

{% stylesheet %}
  .conf-upload-zone {
    width: 100%;
    position: relative;
  }
  
  .conf-upload-input {
    display: none;
  }
  
  .conf-upload-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 180px;
    padding: 24px;
    border: 2px dashed #d1d5db;
    border-radius: 12px;
    background: #f9fafb;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .conf-upload-label:hover {
    border-color: #2c5aa0;
    background: #f0f4ff;
  }
  
  .conf-upload-label:hover .conf-upload-icon {
    transform: translateY(-4px);
    color: #2c5aa0;
  }
  
  .conf-upload-icon {
    margin-bottom: 16px;
    color: #9ca3af;
    transition: all 0.3s ease;
  }
  
  .conf-upload-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  
  .conf-upload-title {
    display: block;
    font-size: 16px;
    font-weight: 600;
    color: #374151;
    margin-bottom: 8px;
  }
  
  .conf-upload-subtitle {
    display: block;
    font-size: 14px;
    color: #6b7280;
    margin-bottom: 8px;
  }
  
  .conf-upload-formats {
    display: block;
    font-size: 12px;
    color: #9ca3af;
  }
  
  .conf-upload-description {
    margin-top: 12px;
    font-size: 13px;
    color: #6b7280;
    text-align: center;
    max-width: 400px;
  }
  
  /* Dropzone active */
  .conf-upload-dropzone {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border: 3px dashed #2c5aa0;
    border-radius: 12px;
    background: rgba(44, 90, 160, 0.05);
    z-index: 10;
  }
  
  .conf-upload-dropzone-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: #2c5aa0;
  }
  
  .conf-upload-dropzone-content svg {
    margin-bottom: 12px;
  }
  
  .conf-upload-dropzone-content p {
    font-size: 16px;
    font-weight: 600;
    margin: 0;
  }
  
  /* Preview */
  .conf-upload-preview {
    margin-top: 16px;
    padding: 16px;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    background: #fff;
  }
  
  .conf-upload-preview-image {
    width: 100%;
    height: 200px;
    margin-bottom: 12px;
    border-radius: 8px;
    overflow: hidden;
    background: #f3f4f6;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .conf-upload-preview-image img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
  
  .conf-upload-preview-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .conf-upload-preview-details {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  
  .conf-upload-preview-name {
    font-size: 14px;
    font-weight: 500;
    color: #374151;
  }
  
  .conf-upload-preview-size {
    font-size: 12px;
    color: #9ca3af;
  }
  
  .conf-upload-preview-actions {
    display: flex;
    gap: 8px;
  }
  
  .conf-upload-preview-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background: #fff;
    cursor: pointer;
    transition: all 0.2s ease;
    color: #6b7280;
  }
  
  .conf-upload-preview-btn:hover {
    background: #f9fafb;
    border-color: #d1d5db;
  }
  
  .conf-upload-remove-btn:hover {
    background: #fef2f2;
    border-color: #fecaca;
    color: #dc2626;
  }
  
  .conf-upload-edit-btn:hover {
    background: #eff6ff;
    border-color: #bfdbfe;
    color: #2c5aa0;
  }
  
  /* Progress */
  .conf-upload-progress {
    margin-top: 12px;
    padding: 12px;
    background: #f9fafb;
    border-radius: 8px;
  }
  
  .conf-upload-progress-bar {
    height: 6px;
    background: #e5e7eb;
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  
  .conf-upload-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #2c5aa0, #3b82f6);
    border-radius: 3px;
    transition: width 0.3s ease;
  }
  
  .conf-upload-progress-text {
    display: block;
    text-align: center;
    font-size: 12px;
    color: #6b7280;
    font-weight: 500;
  }
  
  /* Error */
  .conf-upload-error {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 12px;
    padding: 12px;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
    color: #dc2626;
    font-size: 13px;
  }
  
  .conf-upload-error svg {
    flex-shrink: 0;
  }
  
  @media (max-width: 768px) {
    .conf-upload-label {
      min-height: 160px;
      padding: 20px;
    }
    
    .conf-upload-preview-image {
      height: 150px;
    }
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', function() {
    const uploadZones = document.querySelectorAll('[data-upload-zone]');
    
    uploadZones.forEach(zone => {
      const zoneId = zone.dataset.uploadZone;
      const input = zone.querySelector(`[data-upload="${zoneId}"]`);
      const label = zone.querySelector(`[data-upload-label="${zoneId}"]`);
      const dropzone = zone.querySelector(`[data-dropzone="${zoneId}"]`);
      const preview = zone.querySelector(`[data-preview="${zoneId}"]`);
      const previewImg = zone.querySelector(`[data-preview-img="${zoneId}"]`);
      const previewName = zone.querySelector(`[data-preview-name="${zoneId}"]`);
      const previewSize = zone.querySelector(`[data-preview-size="${zoneId}"]`);
      const removeBtn = zone.querySelector(`[data-upload-remove="${zoneId}"]`);
      const errorDiv = zone.querySelector(`[data-error="${zoneId}"]`);
      const errorMessage = zone.querySelector(`[data-error-message="${zoneId}"]`);
      
      // Gestion du drag & drop
      if (label && dropzone) {
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
          label.addEventListener(eventName, preventDefaults, false);
        });
        
        function preventDefaults(e) {
          e.preventDefault();
          e.stopPropagation();
        }
        
        ['dragenter', 'dragover'].forEach(eventName => {
          label.addEventListener(eventName, () => {
            if (dropzone) dropzone.style.display = 'block';
          });
        });
        
        ['dragleave', 'drop'].forEach(eventName => {
          label.addEventListener(eventName, () => {
            if (dropzone) dropzone.style.display = 'none';
          });
        });
        
        label.addEventListener('drop', (e) => {
          const files = e.dataTransfer.files;
          if (files.length > 0) {
            handleFile(files[0]);
          }
        });
      }
      
      // Gestion de la sélection de fichier
      if (input) {
        input.addEventListener('change', (e) => {
          const files = e.target.files;
          if (files.length > 0) {
            handleFile(files[0]);
          }
        });
      }
      
      // Traitement du fichier
      function handleFile(file) {
        // Cacher l'erreur
        if (errorDiv) errorDiv.style.display = 'none';
        
        // Vérifier le type de fichier
        if (!file.type.startsWith('image/')) {
          showError('Veuillez sélectionner une image valide');
          return;
        }
        
        // Vérifier la taille (5MB max par défaut)
        const maxSize = 5 * 1024 * 1024; // 5MB
        if (file.size > maxSize) {
          showError('Le fichier est trop volumineux (max 5MB)');
          return;
        }
        
        // Afficher la prévisualisation
        const reader = new FileReader();
        
        reader.onload = (e) => {
          if (previewImg) {
            previewImg.src = e.target.result;
          }
          
          if (previewName) {
            previewName.textContent = file.name;
          }
          
          if (previewSize) {
            const sizeKB = (file.size / 1024).toFixed(2);
            previewSize.textContent = sizeKB + ' KB';
          }
          
          if (label) label.style.display = 'none';
          if (preview) preview.style.display = 'block';
          
          // Déclencher un événement personnalisé
          zone.dispatchEvent(new CustomEvent('fileUploaded', {
            detail: { file, dataUrl: e.target.result },
            bubbles: true
          }));
        };
        
        reader.readAsDataURL(file);
      }
      
      // Suppression du fichier
      if (removeBtn) {
        removeBtn.addEventListener('click', (e) => {
          e.preventDefault();
          
          if (input) input.value = '';
          if (previewImg) previewImg.src = '';
          if (label) label.style.display = 'flex';
          if (preview) preview.style.display = 'none';
          if (errorDiv) errorDiv.style.display = 'none';
          
          // Déclencher un événement personnalisé
          zone.dispatchEvent(new CustomEvent('fileRemoved', {
            detail: { zoneId },
            bubbles: true
          }));
        });
      }
      
      // Affichage des erreurs
      function showError(message) {
        if (errorMessage) errorMessage.textContent = message;
        if (errorDiv) errorDiv.style.display = 'flex';
      }
    });
  });
{% endjavascript %}
