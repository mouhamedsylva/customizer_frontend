{% comment %}
  Snippet pour le récapitulatif de droite
{% endcomment %}

<aside class="conf-recap" id="conf-recap">
  <div class="conf-recap-header">
    <h3>RÉCAPITULATIF</h3>
  </div>
  
  <div class="conf-recap-content">
    
    {%- comment -%} Aperçu miniature du produit {%- endcomment -%}
    <div class="conf-recap-preview">
      <img src="" alt="Aperçu produit" data-recap-preview width="200" height="200">
    </div>
    
    {%- comment -%} Détails du produit {%- endcomment -%}
    <div class="conf-recap-details" data-recap-details>
      <div class="conf-recap-product-info">
        <h4 data-recap-product-name>Sweatshirt</h4>
        <div class="conf-recap-specs" data-recap-specs>
          <!-- Sera rempli dynamiquement -->
        </div>
      </div>
    </div>
    
    {%- comment -%} Liste des personnalisations {%- endcomment -%}
    <div class="conf-recap-customizations">
      <h5>Personnalisations</h5>
      <ul class="conf-recap-list" data-recap-customizations>
        <!-- Sera rempli dynamiquement -->
      </ul>
    </div>
    
    {%- comment -%} Quantité {%- endcomment -%}
    <div class="conf-recap-quantity">
      <label>QUANTITÉ</label>
      <p class="conf-quantity-note">Minimum de commande : <span data-min-quantity>1</span> unité</p>
      <div class="conf-quantity-selector">
        <button class="conf-qty-btn" data-action="decrease-qty">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M19 13H5V11H19V13Z" fill="currentColor"/>
          </svg>
        </button>
        <input 
          type="number" 
          class="conf-qty-input" 
          value="1" 
          min="1" 
          data-quantity-input
        >
        <button class="conf-qty-btn" data-action="increase-qty">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M19 13H13V19H11V13H5V11H11V5H13V11H19V13Z" fill="currentColor"/>
          </svg>
        </button>
      </div>
    </div>
    
    {%- comment -%} Prix {%- endcomment -%}
    <div class="conf-recap-pricing">
      <div class="conf-price-row">
        <span>PRIX UNITAIRE</span>
        <strong data-unit-price>0,00 €</strong>
      </div>
      
      <div class="conf-price-discount" data-discount-info style="display: none;">
        <span>Remise (<span data-discount-percent>0</span>%)</span>
        <strong data-discount-amount>-0,00 €</strong>
      </div>
      
      <div class="conf-price-row conf-price-total">
        <span>PRIX TOTAL</span>
        <div class="conf-total-prices">
          <strong class="conf-price-ht" data-total-ht>0,00 €</strong>
          <span class="conf-price-label">HT</span>
        </div>
      </div>
      
      <div class="conf-price-ttc">
        <span class="conf-price-ttc-value" data-total-ttc>0,00 €</span>
        <span class="conf-price-ttc-label">TTC</span>
      </div>
    </div>
    
    {%- comment -%} Actions principales {%- endcomment -%}
    <div class="conf-recap-actions">
      <button class="conf-btn-primary conf-btn-full" data-action="add-to-cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M7 18C5.9 18 5.01 18.9 5.01 20C5.01 21.1 5.9 22 7 22C8.1 22 9 21.1 9 20C9 18.9 8.1 18 7 18ZM1 2V4H3L6.6 11.59L5.25 14.04C5.09 14.32 5 14.65 5 15C5 16.1 5.9 17 7 17H19V15H7.42C7.28 15 7.17 14.89 7.17 14.75L7.2 14.63L8.1 13H15.55C16.3 13 16.96 12.59 17.3 11.97L20.88 5.48C20.96 5.34 21 5.17 21 5C21 4.45 20.55 4 20 4H5.21L4.27 2H1ZM17 18C15.9 18 15.01 18.9 15.01 20C15.01 21.1 15.9 22 17 22C18.1 22 19 21.1 19 20C19 18.9 18.1 18 17 18Z" fill="currentColor"/>
        </svg>
        AJOUTER AU PANIER
      </button>
      
      {% comment %} <button class="conf-btn-secondary conf-btn-full" data-action="save-design">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M17 3H5C3.89 3 3 3.9 3 5V19C3 20.1 3.89 21 5 21H19C20.1 21 21 20.1 21 19V7L17 3ZM19 19H5V5H16.17L19 7.83V19ZM12 12C10.34 12 9 13.34 9 15C9 16.66 10.34 18 12 18C13.66 18 15 16.66 15 15C15 13.34 13.66 12 12 12ZM6 6H15V10H6V6Z" fill="currentColor"/>
        </svg>
        SAUVEGARDER LE DESIGN
      </button> {% endcomment %}
    </div>
    
    {%- comment -%} Informations complémentaires {%- endcomment -%}
    <div class="conf-recap-info">
      <div class="conf-info-item">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M12 1L3 5V11C3 16.55 6.84 21.74 12 23C17.16 21.74 21 16.55 21 11V5L12 1ZM12 11.99H19C18.47 16.11 15.72 19.78 12 20.93V12H5V6.3L12 3.19V11.99Z" fill="currentColor"/>
        </svg>
        <div>
          <strong>Paiement sécurisé</strong>
          <p>Vos paiements sont 100% sécurisés</p>
        </div>
      </div>
      
      <div class="conf-info-item">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M21 16V14L13 9V3.5C13 2.67 12.33 2 11.5 2C10.67 2 10 2.67 10 3.5V9L2 14V16L10 13.5V19L8 20.5V22L11.5 21L15 22V20.5L13 19V13.5L21 16Z" fill="currentColor"/>
        </svg>
        <div>
          <strong>Service client</strong>
          <p>À votre écoute 7j/7</p>
        </div>
      </div>
      
      <div class="conf-info-item">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM13 17H11V15H13V17ZM13 13H11V7H13V13Z" fill="currentColor"/>
        </svg>
        <div>
          <strong>Fabrication de qualité</strong>
          <p>Sublimation haute définition</p>
        </div>
      </div>
      
      <div class="conf-info-item">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M20 8H17V4H7V8H4C2.9 8 2 8.9 2 10V14C2 15.1 2.9 16 4 16H7V20H17V16H20C21.1 16 22 15.1 22 14V10C22 8.9 21.1 8 20 8ZM15 18H9V14H15V18ZM15 8H9V6H15V8Z" fill="currentColor"/>
        </svg>
        <div>
          <strong>Livraison rapide</strong>
          <p>Expédition sous 5 à 7 jours ouvrés</p>
        </div>
      </div>
    </div>
    
    {%- comment -%} Note de bas {%- endcomment -%}
    <div class="conf-recap-note">
      <p><strong>Paiement sécurisé</strong></p>
      <div class="conf-payment-methods">
        <img src="{{ 'img/visa.svg' | asset_url }}" alt="Visa" width="40" height="24">
        <img src="{{ 'img/mastercard.svg' | asset_url }}" alt="Mastercard" width="40" height="24">
        <img src="{{ 'img/paypal.svg' | asset_url }}" alt="PayPal" width="40" height="24">
        <img src="{{ 'img/applepay.svg' | asset_url }}" alt="Apple Pay" width="40" height="24">
      </div>
    </div>
    
  </div>
</aside>

{% stylesheet %}
  .conf-recap {
    width: 380px;
    background: #fff;
    border-left: 1px solid #e5e5e5;
    height: 100%;
    overflow-y: auto;
    position: sticky;
    top: 0;
  }
  
  .conf-recap-header {
    padding: 20px;
    border-bottom: 1px solid #e5e5e5;
  }
  
  .conf-recap-header h3 {
    margin: 0;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1px;
  }
  
  .conf-recap-content {
    padding: 20px;
  }
  
  .conf-recap-preview {
    width: 100%;
    aspect-ratio: 1;
    background: #f8f8f8;
    border-radius: 8px;
    margin-bottom: 20px;
    overflow: hidden;
  }
  
  .conf-recap-preview img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  
  .conf-recap-details {
    margin-bottom: 20px;
  }
  
  .conf-recap-product-info h4 {
    font-size: 18px;
    margin: 0 0 8px 0;
  }
  
  .conf-recap-specs {
    font-size: 13px;
    color: #666;
  }
  
  .conf-recap-specs p {
    margin: 4px 0;
  }
  
  .conf-recap-customizations {
    margin-bottom: 20px;
    padding: 16px;
    background: #f8f8f8;
    border-radius: 8px;
  }
  
  .conf-recap-customizations h5 {
    font-size: 14px;
    margin: 0 0 12px 0;
  }
  
  .conf-recap-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .conf-recap-list li {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    font-size: 13px;
    border-bottom: 1px solid #e5e5e5;
  }
  
  .conf-recap-list li:last-child {
    border-bottom: none;
  }
  
  .conf-quantity-selector {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 12px;
  }
  
  .conf-qty-btn {
    width: 40px;
    height: 40px;
    border: 1px solid #ddd;
    background: #fff;
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }
  
  .conf-qty-btn:hover {
    background: #f5f5f5;
    border-color: #999;
  }
  
  .conf-qty-input {
    flex: 1;
    height: 40px;
    text-align: center;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 16px;
    font-weight: 600;
  }
  
  .conf-recap-pricing {
    margin: 24px 0;
    padding: 20px;
    background: #f8f8f8;
    border-radius: 8px;
  }
  
  .conf-price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    font-size: 14px;
  }
  
  .conf-price-total {
    padding-top: 12px;
    border-top: 1px solid #ddd;
    margin-bottom: 8px;
  }
  
  .conf-price-ttc {
    display: flex;
    justify-content: flex-end;
    align-items: baseline;
    gap: 8px;
    margin-top: 8px;
  }
  
  .conf-price-ttc-value {
    font-size: 32px;
    font-weight: 700;
    color: #2c5aa0;
  }
  
  .conf-price-ttc-label {
    font-size: 14px;
    color: #666;
  }
  
  .conf-recap-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
  }
  
  .conf-btn-full {
    width: 100%;
    justify-content: center;
  }
  
  .conf-recap-info {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid #e5e5e5;
  }
  
  .conf-info-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  
  .conf-info-item svg {
    flex-shrink: 0;
    color: #2c5aa0;
  }
  
  .conf-info-item strong {
    display: block;
    font-size: 13px;
    margin-bottom: 4px;
  }
  
  .conf-info-item p {
    font-size: 12px;
    color: #666;
    margin: 0;
  }
  
  .conf-payment-methods {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }
  
  .conf-payment-methods img {
    height: 24px;
  }
{% endstylesheet %}
