<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --black: #1a1a1a;
    --muted: #888;
    --faint: #aaa;
    --border: #e8e8e8;
    --bg-light: #fafafa;
  }
  .recap-page {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    color: var(--black);
    background: #fff;
    min-height: 100vh;
  }

  /* Header + étapes (repris du configurateur) */
  .rcp-hdr {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 24px; border-bottom: 1px solid var(--border);
    flex-wrap: wrap; gap: 16px;
  }
  .rcp-brand { display: flex; align-items: center; gap: 12px; }
  .rcp-brand-icon {
    width: 40px; height: 40px; border-radius: 8px; background: var(--black);
    color: #fff; display: flex; align-items: center; justify-content: center; font-size: 20px;
  }
  .rcp-brand-name { font-size: 15px; font-weight: 800; letter-spacing: .3px; }
  .rcp-brand-sub { font-size: 11px; color: var(--muted); }

  .rcp-steps { display: flex; align-items: center; gap: 8px; }
  .rcp-step { display: flex; align-items: center; gap: 6px; color: var(--muted); font-size: 12px; }
  .rcp-step-n {
    width: 22px; height: 22px; border-radius: 50%; border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700;
  }
  .rcp-step.on .rcp-step-n { background: var(--black); border-color: var(--black); color: #fff; }
  .rcp-step.on .rcp-step-lbl { color: var(--black); font-weight: 600; }
  .rcp-step-line { width: 36px; height: 1px; background: var(--border); }

  .rcp-back {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 14px; border: 1px solid var(--border); border-radius: 8px;
    background: #fff; font-size: 12px; font-weight: 600; color: var(--black);
    cursor: pointer; text-decoration: none;
  }
  .rcp-back:hover { background: var(--bg-light); }

  /* Corps */
  .rcp-body {
    max-width: 1100px; margin: 0 auto; padding: 32px 24px 60px;
    display: grid; grid-template-columns: 1fr 340px; gap: 32px;
  }
  @media (max-width: 900px) { .rcp-body { grid-template-columns: 1fr; } }

  .rcp-title { font-size: 22px; font-weight: 800; margin-bottom: 4px; }
  .rcp-subtitle { font-size: 13px; color: var(--muted); margin-bottom: 24px; }

  /* Liste des produits */
  .rcp-items { display: flex; flex-direction: column; gap: 14px; }
  .rcp-item {
    display: flex; gap: 16px; align-items: center;
    padding: 16px; border: 1px solid var(--border); border-radius: 12px; background: #fff;
  }
  .rcp-item-img {
    width: 84px; height: 84px; border-radius: 8px; flex-shrink: 0;
    background: var(--bg-light); border: 1px solid var(--border);
    object-fit: contain;
  }
  .rcp-item-noimg {
    display: flex; align-items: center; justify-content: center;
  }
  .rcp-item-info { flex: 1; min-width: 0; }
  .rcp-item-name { font-size: 15px; font-weight: 700; margin-bottom: 4px; }
  .rcp-item-props { font-size: 11px; color: var(--muted); line-height: 1.5; }
  .rcp-item-props span { display: inline-block; margin-right: 10px; }
  .rcp-item-right { text-align: right; flex-shrink: 0; }
  .rcp-item-price { font-size: 15px; font-weight: 800; }
  .rcp-item-qty { font-size: 11px; color: var(--muted); margin-top: 2px; }
  .rcp-item-remove {
    margin-top: 8px; font-size: 11px; color: #c0392b; background: none; border: none;
    cursor: pointer; font-weight: 600;
  }
  .rcp-item-remove:hover { text-decoration: underline; }

  .rcp-empty {
    text-align: center; padding: 60px 20px; color: var(--muted);
    border: 1px dashed var(--border); border-radius: 12px;
  }
  .rcp-empty a { color: var(--black); font-weight: 700; }

  /* Récap prix (colonne droite) */
  .rcp-summary {
    border: 1px solid var(--border); border-radius: 12px; padding: 20px;
    position: sticky; top: 24px; height: fit-content;
  }
  .rcp-summary-title {
    font-size: 12px; font-weight: 800; letter-spacing: .5px;
    text-transform: uppercase; margin-bottom: 16px;
  }
  .rcp-line { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 10px; color: #444; }
  .rcp-line-total {
    display: flex; justify-content: space-between; align-items: baseline;
    font-size: 18px; font-weight: 800; margin-top: 14px; padding-top: 14px;
    border-top: 1px solid var(--border);
  }
  .rcp-total-vat { font-size: 11px; color: var(--muted); font-weight: 400; }
  .rcp-note { font-size: 10px; color: var(--faint); margin-top: 4px; }

  /* Consentement (au-dessus du bouton Commander). */
  .rcp-consent {
    display: flex; align-items: flex-start; gap: 10px;
    margin-top: 18px; padding: 12px 14px;
    background: #f8f8f8; border: 1px solid var(--border); border-radius: 10px;
    font-size: 12px; line-height: 1.5; color: #444; cursor: pointer;
    transition: border-color .15s, background .15s;
  }
  .rcp-consent:hover { border-color: #bbb; }
  .rcp-consent input {
    flex: none; width: 17px; height: 17px; margin-top: 1px;
    accent-color: var(--black); cursor: pointer;
  }
  .rcp-consent a { color: var(--black); text-decoration: underline; }
  /* Mise en avant discrète tant que ce n'est pas coché. */
  .rcp-consent:has(input:not(:checked)) { border-color: #e0c088; background: #fdf8ee; }

  .rcp-continue {
    width: 100%; margin-top: 14px; padding: 14px; background: var(--black); color: #fff;
    border: none; border-radius: 10px; font-size: 14px; font-weight: 700; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    transition: background .2s, opacity .2s;
  }
  .rcp-continue:hover:not(:disabled) { background: #333; }
  .rcp-continue:disabled { opacity: .45; cursor: not-allowed; }

  .rcp-return {
    width: 100%; margin-top: 10px; padding: 12px; background: #fff; color: var(--black);
    border: 1px solid var(--border); border-radius: 10px; font-size: 13px; font-weight: 600;
    cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 6px;
    transition: background .2s;
  }
  .rcp-return:hover { background: var(--bg-light); }

  .rcp-trust { margin-top: 18px; display: flex; flex-direction: column; gap: 10px; }
  .rcp-trust-item { display: flex; gap: 8px; align-items: flex-start; font-size: 11px; color: #555; }
  .rcp-trust-item svg { flex-shrink: 0; margin-top: 1px; }
</style>

<div class="recap-page">
  <!-- Header + étapes -->
  <header class="rcp-hdr">
    <div class="rcp-brand">
      <div class="rcp-brand-icon">🛒</div>
      <div>
        <div class="rcp-brand-name">RÉCAPITULATIF</div>
        <div class="rcp-brand-sub">Vérifiez votre commande</div>
      </div>
    </div>

    <div class="rcp-steps">
      <div class="rcp-step">
        <div class="rcp-step-n">1</div>
        <span class="rcp-step-lbl">Personnalisation</span>
      </div>
      <div class="rcp-step-line"></div>
      <div class="rcp-step on">
        <div class="rcp-step-n">2</div>
        <span class="rcp-step-lbl">Récapitulatif</span>
      </div>
      <div class="rcp-step-line"></div>
      <div class="rcp-step">
        <div class="rcp-step-n">3</div>
        <span class="rcp-step-lbl">Commande</span>
      </div>
    </div>

    <a href="/pages/configurateur" class="rcp-back">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
      Modifier
    </a>
  </header>

  <!-- Corps -->
  <div class="rcp-body">
    <div>
      <h1 class="rcp-title">Votre récapitulatif</h1>
      <p class="rcp-subtitle">Vérifiez les produits et les prix avant de passer commande.</p>
      <div class="rcp-items" id="rcp-items">
        <!-- Rempli par JS depuis /cart.js -->
        <div class="rcp-empty">Chargement du panier…</div>
      </div>
    </div>

    <!-- Récap prix -->
    <aside class="rcp-summary">
      <div class="rcp-summary-title">Récapitulatif du prix</div>
      <div class="rcp-line">
        <span>Sous-total</span>
        <span id="rcp-subtotal">—</span>
      </div>
      <div class="rcp-line">
        <span>Livraison</span>
        <span>Calculée à l'étape suivante</span>
      </div>
      <div class="rcp-line-total">
        <span>Total</span>
        <span><span id="rcp-total">—</span> <span class="rcp-total-vat">TTC</span></span>
      </div>
      <p class="rcp-note">Taxes incluses. Livraison calculée à l'étape suivante.</p>

      <!-- Consentement : le bouton Commander reste bloqué tant que la case
           n'est pas cochée. Article personnalisé = pas de retour possible,
           d'où l'acceptation explicite avant paiement. -->
      <label class="rcp-consent" for="rcp-consent-chk">
        <input type="checkbox" id="rcp-consent-chk" onchange="onConsentChange()">
        <span>
          J'ai vérifié mon design (texte, couleurs, placement) et j'accepte les
          <a href="/policies/terms-of-service" target="_blank" rel="noopener">conditions générales de vente</a>.
          Les articles personnalisés ne sont ni repris ni échangés.
        </span>
      </label>

      <button class="rcp-continue" id="rcp-continue" onclick="goToCheckout(this)" disabled>
        Commander
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
      </button>
      <button class="rcp-return" onclick="window.location.href='/pages/configurateur'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
        Retour au configurateur
      </button>

      <div class="rcp-trust">
        <div class="rcp-trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#666"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"/></svg>
          Paiement 100% sécurisé
        </div>
        <div class="rcp-trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#666"><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4z"/></svg>
          Livraison rapide sous 5 à 7 jours
        </div>
      </div>
    </aside>
  </div>
</div>

<script src="{{ 'conf-alert.js' | asset_url }}"></script>
<script>
  // Variants Shopify pour le panier natif (produits à prix fixe).
  // coins n'a pas de variant : il passe par une demande de devis.
  var CONF_VARIANTS = {
    sweatshirt:       47843224944803,
    tshirt:           47843225338019,
    tshirt_polyester: 47843228319907,
    drapeaux:         47843229270179,
    patches:          47843295428771
  };

  // Variants par COULEUR (produits textiles avec option Couleur dans Shopify).
  // Permet à la vignette du checkout Shopify de prendre la bonne couleur.
  // Les produits/couleurs absents ici retombent sur CONF_VARIANTS (variant de base).
  var CONF_COLOR_VARIANTS = {
    sweatshirt: {
      'Noir':         47846803407011,
      'Blanc cassé':  47846803439779,
      'Gris':         47846803472547,
      'Gris foncé':   47846803505315,
      'Gris ardoise': 47846803538083,
      'Bleu marine':  47846803570851,
      'Bleu ciel':    47846803603619,
      'Vert foncé':   47846803636387,
      'Rose clair':   47846803669155,
      'Rose':         47846803701923,
      'Rouge':        47846803734691,
      'Orange':       47846803767459,
      'Jaune':        47846803800227,
      'Violet':       47846803832995,
      'Marron':       47846803865763
    },
    tshirt: {
      'Noir':         47846855114915,
      'Blanc cassé':  47846855147683,
      'Gris':         47846855180451,
      'Gris foncé':   47846855213219,
      'Gris ardoise': 47846855245987,
      'Bleu marine':  47846855278755,
      'Bleu ciel':    47846855311523,
      'Vert foncé':   47846855344291,
      'Rose clair':   47846855377059,
      'Rose':         47846855409827,
      'Rouge':        47846855442595,
      'Orange':       47846855475363,
      'Jaune':        47846855508131,
      'Violet':       47846855540899,
      'Marron':       47846855573667
    },
    tshirt_polyester: {
      'Noir':         47846855901347,
      'Blanc cassé':  47846855934115,
      'Gris':         47846855966883,
      'Gris foncé':   47846855999651,
      'Gris ardoise': 47846856032419,
      'Bleu marine':  47846856065187,
      'Bleu ciel':    47846856097955,
      'Vert foncé':   47846856130723,
      'Rose clair':   47846856163491,
      'Rose':         47846856196259,
      'Rouge':        47846856229027,
      'Orange':       47846856261795,
      'Jaune':        47846856294563,
      'Violet':       47846856327331,
      'Marron':       47846856360099
    },
    // DRAPEAUX : variants par couleur de fond.
    // Tant que ce bloc est vide, la commande utilise le variant de base
    // (CONF_VARIANTS.drapeaux) et la couleur reste dans les propriétés.
    // Pour activer : créer les variants Couleur du produit Drapeau dans Shopify
    // puis coller ici les IDs, ex. 'Rouge': 47xxxxxxxxxxx.
    drapeaux: {}
  };

  // Correspondance : nouvelle couleur (palette 40, EN) -> couleur FR qui a un
  // variant Shopify existant. Tant que les 40 vrais variants ne sont pas créés,
  // on rattache la commande au variant FR le plus proche (la couleur RÉELLE
  // choisie reste dans les propriétés de la ligne, visible en production).
  var COLOR_EN_TO_FR = {
    'black': 'Noir', 'used black': 'Noir',
    'white': 'Blanc cassé', 'ash': 'Blanc cassé', 'natural': 'Blanc cassé', 'sand': 'Blanc cassé',
    'navy': 'Bleu marine', 'navy blue': 'Bleu marine', 'cobalt blue': 'Bleu marine',
    'royal blue': 'Bleu marine', 'urban purple': 'Bleu marine', 'stone blue': 'Bleu marine',
    'diva blue': 'Bleu marine',
    'sky': 'Bleu ciel', 'atoll': 'Bleu ciel', 'swimming pool': 'Bleu ciel',
    'millennial mint': 'Bleu ciel', 'millennial lilac': 'Bleu ciel',
    'red': 'Rouge', 'fire red': 'Rouge', 'burgundy': 'Rouge',
    'orange': 'Orange', 'urban orange': 'Orange', 'sunset orange': 'Orange', 'apricot': 'Orange',
    'gold': 'Jaune', 'solar yellow': 'Jaune',
    'brown': 'Marron', 'chocolate': 'Marron',
    'bottle green': 'Vert foncé', 'kelly green': 'Vert foncé', 'urban khaki': 'Vert foncé',
    'orchid green': 'Vert foncé', 'pixel lime': 'Vert foncé',
    'radiant purple': 'Violet',
    'orchid pink': 'Rose clair', 'sorbet': 'Rose',
    'dark grey': 'Gris foncé', 'pacific grey': 'Gris', 'sport grey': 'Gris ardoise'
  };

  // Extrait le nom de couleur depuis le champ "color" d'un item.
  // - Textiles : "Couleur : Violet" -> "Violet"
  // - Drapeaux/patchs : les détails sont concaténés
  //   ("Type : Recto verso · Couleur : Rouge · Taille : …") -> on isole la couleur.
  function colorNameFromItem(it) {
    if (!it || !it.color) return '';
    var raw = String(it.color);
    var m = raw.match(/Couleur\s*:\s*([^·|]+)/i);
    if (m) return m[1].trim();
    return raw.replace(/^\s*Couleur\s*:\s*/i, '').trim();
  }

  // Normalise un nom de couleur pour un matching robuste : minuscules, sans
  // accents, espaces compactés. Évite les échecs dus à la casse / aux accents
  // (ex. "Vert foncé" encodé différemment) qui feraient retomber sur le variant
  // de base (donc la mauvaise couleur au checkout).
  function normColor(s) {
    return String(s == null ? '' : s)
      .normalize('NFD').replace(/[̀-ͯ]/g, '') // retire les accents
      .toLowerCase().replace(/\s+/g, ' ').trim();
  }

  // Choisit le variant : d'abord par couleur (matching normalisé) si dispo,
  // sinon variant de base.
  function variantForItem(it) {
    var byColor = CONF_COLOR_VARIANTS[it.productType];
    if (byColor) {
      var rawName = colorNameFromItem(it);
      var target = normColor(rawName);
      if (target) {
        // 1) Correspondance directe avec un variant FR existant.
        for (var label in byColor) {
          if (Object.prototype.hasOwnProperty.call(byColor, label) &&
              normColor(label) === target) {
            return byColor[label];
          }
        }
        // 2) Nouvelle couleur (palette 40) -> variant FR le plus proche.
        var frName = COLOR_EN_TO_FR[target];
        if (frName && byColor[frName]) {
          return byColor[frName];
        }
        // 3) Repli sûr : premier variant du produit (évite "Cannot find variant").
        for (var k in byColor) {
          if (Object.prototype.hasOwnProperty.call(byColor, k)) return byColor[k];
        }
      }
    }
    return CONF_VARIANTS[it.productType];
  }

  (function () {
    function money(val) {
      return (Number(val) || 0).toFixed(2).replace('.', ',') + ' €';
    }

    /* Prix DÉGRESSIF par quantité : grille + helpers déportés dans l'asset
       partagé conf-pricing-tiers.js (chargé plus haut). On délègue aux globals
       window.* ; repli local minimal si l'asset n'a pas chargé. */
    function effectiveUnitPrice(item, totalsByType) {
      if (typeof window.effectiveUnitPrice === 'function') {
        return window.effectiveUnitPrice(item, totalsByType);
      }
      return Number(item && item.price) || 0;   // repli : prix de la ligne
    }
    function esc(s) {
      return String(s == null ? '' : s)
        .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function getCart() {
      try { return JSON.parse(sessionStorage.getItem('conf_cart')) || []; }
      catch (e) { return []; }
    }
    function saveCart(items) {
      try { sessionStorage.setItem('conf_cart', JSON.stringify(items)); } catch (e) {}
    }

    /* Construit les line items Shopify à partir du panier local.
       Chaque item est rattaché à son variant via productType. Les propriétés
       de personnalisation (détails, taille, aperçu) sont jointes à la ligne.
       Les coins n'ont pas de variant : ils passent par une demande de devis
       et sont ignorés ici. */
    function buildShopifyItems(cart) {
      var items = [], skipped = [];
      cart.forEach(function (it) {
        var variantId = variantForItem(it);
        if (!variantId) { skipped.push(it); return; }

        var properties = {};
        // Visibles au checkout (utiles au client) : personne + couleur + taille.
        // « Personne » vient d'une liste de groupe : chaque ligne de la commande
        // indique alors à qui le vêtement est destiné (nécessaire à l'atelier).
        if (it.personName) properties['Personne'] = it.personName;
        // Rattache la ligne à sa liste de groupe : les lignes d'une même
        // commande restent lisibles comme un ensemble (« 2/5 »).
        if (it.groupLabel) properties['Liste'] = it.groupLabel;
        if (it.groupIndex) properties['Ligne'] = it.groupIndex;
        if (it.color) properties['Détails'] = it.color;
        if (it.size)  properties['Taille'] = it.size;

        // N'accepte QUE des URLs http(s) hébergées comme valeur de propriété.
        // Une data-URL (base64) ferait des milliers de caractères -> Shopify
        // REJETTE /cart/add.js (propriété trop longue) et le checkout échoue.
        var httpUrl = function (u) {
          return (typeof u === 'string' && /^https?:\/\//i.test(u)) ? u : null;
        };

        // URLs techniques (aperçu + logos) : préfixe "_" -> cachées au checkout,
        // visibles dans l'admin. Aperçu = planche (sheet) si dispo, sinon vignette.
        var apercu = httpUrl(it.sheet) || httpUrl(it.img);
        if (apercu) properties['_Aperçu'] = apercu;
        if (Array.isArray(it.assets)) {
          it.assets.forEach(function (a) {
            if (a && a.label && httpUrl(a.url)) properties['_' + a.label] = a.url;
          });
        }

        var qty = Math.max(1, parseInt(it.qty, 10) || 1);
        items.push({
          id: variantId,
          quantity: qty,
          properties: Object.keys(properties).length ? properties : undefined
        });

        // Supplément « personnalisation manches » : ligne de panier distincte.
        // Le variant textile a un prix fixe et une line item property ne porte
        // aucun prix — le supplément doit donc être un vrai article (produit
        // add-on masqué). Quantité = nb de manches × quantité de l'article.
        var sleeves = Math.max(0, parseInt(it.sleeveCount, 10) || 0);
        if (sleeves > 0 && window.CONF_SLEEVE_VARIANT) {
          items.push({
            id: window.CONF_SLEEVE_VARIANT,
            quantity: sleeves * qty,
            properties: {
              'Article': (it.name || 'Textile') + (it.size ? ' — ' + it.size : ''),
              'Manches': sleeves > 1 ? 'Gauche + droite' : 'Une manche'
            }
          });
        }
      });
      return { items: items, skipped: skipped };
    }

    /* Synchronise le panier local vers le panier natif Shopify puis redirige
       vers le checkout Shopify (où le client saisit ses coordonnées et paie). */
    /* Active/désactive le bouton Commander selon la case de consentement.
       Exposé sur window : l'attribut onchange="..." s'exécute dans le scope
       GLOBAL, pas dans cette IIFE. Sans ça, la case ne débloquait rien. */
    function onConsentChange() {
      var chk = document.getElementById('rcp-consent-chk');
      var btn = document.getElementById('rcp-continue');
      if (!btn) return;
      var ok = !!(chk && chk.checked);
      btn.disabled = !ok;
      // render() peut avoir posé ces styles inline pour un panier vide :
      // on les nettoie pour ne pas laisser le bouton inerte.
      btn.style.pointerEvents = ok ? '' : 'none';
      btn.style.opacity = ok ? '' : '';
    }
    window.onConsentChange = onConsentChange;

    async function goToCheckout(btnEl) {
      // Garde-fou : consentement obligatoire (au cas où le bouton serait forcé).
      var consent = document.getElementById('rcp-consent-chk');
      if (!consent || !consent.checked) {
        await confAlert(
          'Merci d\'accepter les conditions avant de commander.',
          { icon: 'info', title: 'Consentement requis' }
        );
        return;
      }

      var cart = getCart();
      if (!cart.length) { await confAlert('Votre panier est vide.', { icon: 'info', title: 'Panier vide' }); return; }

      var built = buildShopifyItems(cart);
      var items = built.items, skipped = built.skipped;

      // Panier composé uniquement d'articles sur devis (coins) : pas de checkout.
      if (!items.length) {
        await confAlert(
          "Votre panier ne contient que des articles sur devis (coins). " +
          "Utilisez le bouton « Faire une demande de devis » depuis le configurateur.",
          { icon: 'info', title: 'Articles sur devis' }
        );
        return;
      }
      if (skipped.length) {
        var ok = await confConfirm(
          skipped.length + " article(s) sur devis (coins) ne peuvent pas être payés en ligne " +
          "et seront retirés. Continuer avec les " + items.length + " autre(s) article(s) ?",
          { icon: 'warning', title: 'Articles retirés', confirmText: 'Continuer' }
        );
        if (!ok) return;
      }

      if (btnEl) { btnEl.disabled = true; btnEl.textContent = 'Redirection…'; }

      try {
        // 1) On repart d'un panier Shopify propre (évite les doublons au retour).
        await fetch('/cart/clear.js', { method: 'POST' });

        // 2) Ajout de tous les articles au panier natif Shopify.
        var res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: items })
        });
        if (!res.ok) {
          var txt = await res.text().catch(function () { return ''; });
          throw new Error('Ajout au panier Shopify échoué (' + res.status + '). ' + txt);
        }

        // 3) Marque qu'un checkout est en cours. Au retour sur le configurateur,
        //    si le panier Shopify natif est vide (commande finalisée), on purge le
        //    design. On NE purge PAS ici : le client peut revenir en arrière et
        //    doit retrouver son panier tant que le paiement n'est pas confirmé.
        try { localStorage.setItem('conf_checkout_pending', String(Date.now())); } catch (e) {}
        window.location.href = '/checkout';
      } catch (err) {
        console.error('Erreur checkout :', err);
        if (btnEl) { btnEl.disabled = false; btnEl.textContent = 'Commander'; }
        confAlert("Une erreur est survenue lors du passage au paiement.\n" + err.message, { icon: 'error', title: 'Erreur' });
      }
    }

    // Exposé pour le onclick inline du bouton "Commander".
    window.goToCheckout = goToCheckout;

    function render() {
      const items = getCart();
      const itemsEl = document.getElementById('rcp-items');
      const contBtn = document.getElementById('rcp-continue');

      if (!items.length) {
        itemsEl.innerHTML = `
          <div class="rcp-empty">
            Votre récapitulatif est vide.<br>
            <a href="/pages/configurateur">← Retour au configurateur</a>
          </div>`;
        document.getElementById('rcp-subtotal').textContent = money(0);
        document.getElementById('rcp-total').textContent = money(0);
        contBtn.disabled = true;
        contBtn.style.opacity = '0.5';
        contBtn.style.pointerEvents = 'none';
        return;
      }

      // Panier non vide : on lève le verrou « panier vide » posé plus haut.
      // Le bouton reste toutefois soumis à la case de consentement.
      contBtn.style.opacity = '';
      contBtn.style.pointerEvents = '';
      if (typeof onConsentChange === 'function') onConsentChange();

      // Quantité totale par type -> palier dégressif appliqué à l'affichage.
      var totalsByType = {};
      items.forEach(function (i) {
        totalsByType[i.productType] = (totalsByType[i.productType] || 0) + (i.qty || 1);
      });

      let subtotal = 0;
      itemsEl.innerHTML = items.map((item, idx) => {
        const unit = effectiveUnitPrice(item, totalsByType);
        const lineTotal = unit * (item.qty || 1);
        subtotal += lineTotal;

        // Propriétés : textile = couleur + taille séparés ; custom = détails bruts
        let propsHtml = '';
        if (item.size) {
          const parts = [];
          if (item.color) parts.push(`<span><strong>Couleur :</strong> ${esc(item.color)}</span>`);
          parts.push(`<span><strong>Taille :</strong> ${esc(item.size)}</span>`);
          propsHtml = parts.join('');
        } else if (item.color) {
          // Custom (drapeau/patch) : les détails sont déjà formatés
          propsHtml = `<span>${esc(item.color)}</span>`;
        }

        const img = item.img
          ? `<img class="rcp-item-img" src="${esc(item.img)}" alt="${esc(item.name)}">`
          : `<div class="rcp-item-img rcp-item-noimg">
               <svg width="32" height="32" viewBox="0 0 24 24" fill="#c9ccd1"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
             </div>`;
        return `
          <div class="rcp-item">
            ${img}
            <div class="rcp-item-info">
              <div class="rcp-item-name">${esc(item.name)}</div>
              <div class="rcp-item-props">${propsHtml}</div>
            </div>
            <div class="rcp-item-right">
              <div class="rcp-item-price">${money(lineTotal)}</div>
              <div class="rcp-item-qty">Qté : ${item.qty || 1}</div>
              <button class="rcp-item-remove" data-idx="${idx}">Retirer</button>
            </div>
          </div>`;
      }).join('');

      document.getElementById('rcp-subtotal').textContent = money(subtotal);
      document.getElementById('rcp-total').textContent = money(subtotal);

      // Boutons "Retirer"
      itemsEl.querySelectorAll('.rcp-item-remove').forEach(btn => {
        btn.addEventListener('click', () => {
          const list = getCart();
          list.splice(parseInt(btn.dataset.idx, 10), 1);
          saveCart(list);
          render();
        });
      });
    }

    render();
  })();
</script>

{% schema %}
{
  "name": "Récapitulatif",
  "settings": []
}
{% endschema %}
