<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --black: #1a1a1a;
    --muted: #888;
    --faint: #aaa;
    --border: #e8e8e8;
    --bg-light: #fafafa;
  }
  .cmd-page {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    color: var(--black);
    background: #fff;
    min-height: 100vh;
  }

  /* Header + étapes */
  .cmd-hdr {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 24px; border-bottom: 1px solid var(--border);
    flex-wrap: wrap; gap: 16px;
  }
  .cmd-brand { display: flex; align-items: center; gap: 12px; }
  .cmd-brand-icon {
    width: 40px; height: 40px; border-radius: 8px; background: var(--black);
    color: #fff; display: flex; align-items: center; justify-content: center; font-size: 20px;
  }
  .cmd-brand-name { font-size: 15px; font-weight: 800; letter-spacing: .3px; }
  .cmd-brand-sub { font-size: 11px; color: var(--muted); }

  .cmd-steps { display: flex; align-items: center; gap: 8px; }
  .cmd-step { display: flex; align-items: center; gap: 6px; color: var(--muted); font-size: 12px; }
  .cmd-step-n {
    width: 22px; height: 22px; border-radius: 50%; border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700;
  }
  .cmd-step.on .cmd-step-n { background: var(--black); border-color: var(--black); color: #fff; }
  .cmd-step.on .cmd-step-lbl { color: var(--black); font-weight: 600; }
  .cmd-step-line { width: 36px; height: 1px; background: var(--border); }

  .cmd-back {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 14px; border: 1px solid var(--border); border-radius: 8px;
    background: #fff; font-size: 12px; font-weight: 600; color: var(--black);
    cursor: pointer; text-decoration: none;
  }
  .cmd-back:hover { background: var(--bg-light); }

  /* Corps */
  .cmd-body {
    max-width: 1100px; margin: 0 auto; padding: 32px 24px 60px;
    display: grid; grid-template-columns: 1fr 360px; gap: 32px;
  }
  @media (max-width: 900px) { .cmd-body { grid-template-columns: 1fr; } }

  .cmd-title { font-size: 22px; font-weight: 800; margin-bottom: 4px; }
  .cmd-subtitle { font-size: 13px; color: var(--muted); margin-bottom: 24px; }

  /* Formulaire */
  .cmd-form { display: flex; flex-direction: column; gap: 18px; }
  .cmd-field-group {
    border: 1px solid var(--border); border-radius: 12px; padding: 20px;
  }
  .cmd-group-title {
    font-size: 13px; font-weight: 800; text-transform: uppercase;
    letter-spacing: .5px; margin-bottom: 16px;
  }
  .cmd-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  @media (max-width: 560px) { .cmd-row { grid-template-columns: 1fr; } }
  .cmd-field { margin-bottom: 14px; }
  .cmd-field:last-child { margin-bottom: 0; }
  .cmd-field label {
    display: block; font-size: 12px; font-weight: 600; margin-bottom: 6px; color: #444;
  }
  .cmd-field input, .cmd-field textarea, .cmd-field select {
    width: 100%; padding: 11px 12px; border: 1.5px solid var(--border);
    border-radius: 8px; font-size: 13px; font-family: inherit; color: var(--black);
  }
  .cmd-field input:focus, .cmd-field textarea:focus, .cmd-field select:focus {
    outline: none; border-color: var(--black);
  }
  .cmd-field textarea { resize: vertical; min-height: 80px; }
  .cmd-field .req { color: #c0392b; }
  .cmd-error { font-size: 11px; color: #c0392b; margin-top: 4px; display: none; }

  /* Récap (colonne droite) */
  .cmd-summary {
    border: 1px solid var(--border); border-radius: 12px; padding: 20px;
    position: sticky; top: 24px; height: fit-content;
  }
  .cmd-summary-title {
    font-size: 12px; font-weight: 800; letter-spacing: .5px;
    text-transform: uppercase; margin-bottom: 16px;
  }
  .cmd-sum-item {
    display: flex; gap: 12px; align-items: center; padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }
  .cmd-sum-img {
    width: 48px; height: 48px; border-radius: 6px; flex-shrink: 0;
    background: var(--bg-light); border: 1px solid var(--border); object-fit: contain;
    display: flex; align-items: center; justify-content: center;
  }
  .cmd-sum-info { flex: 1; min-width: 0; }
  .cmd-sum-name { font-size: 13px; font-weight: 700; }
  .cmd-sum-qty { font-size: 11px; color: var(--muted); }
  .cmd-sum-price { font-size: 13px; font-weight: 700; white-space: nowrap; }

  .cmd-line-total {
    display: flex; justify-content: space-between; align-items: baseline;
    font-size: 18px; font-weight: 800; margin-top: 16px; padding-top: 14px;
    border-top: 2px solid var(--border);
  }
  .cmd-total-vat { font-size: 11px; color: var(--muted); font-weight: 400; }

  .cmd-submit {
    width: 100%; margin-top: 20px; padding: 15px; background: var(--black); color: #fff;
    border: none; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    transition: background .2s;
  }
  .cmd-submit:hover { background: #333; }
  .cmd-submit:disabled { opacity: .5; cursor: not-allowed; }

  .cmd-cancel {
    width: 100%; margin-top: 10px; padding: 12px; background: #fff; color: #c0392b;
    border: 1px solid var(--border); border-radius: 10px; font-size: 13px; font-weight: 600;
    cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 6px;
    transition: all .2s;
  }
  .cmd-cancel:hover { background: #fdf0ee; border-color: #c0392b; }

  .cmd-success {
    text-align: center; padding: 60px 20px;
  }
  .cmd-success-icon {
    width: 72px; height: 72px; margin: 0 auto 20px; border-radius: 50%;
    background: #e8f7ee; color: #16a34a; display: flex; align-items: center; justify-content: center;
  }
  .cmd-success h2 { font-size: 22px; margin-bottom: 8px; }
  .cmd-success p { color: var(--muted); font-size: 14px; margin-bottom: 24px; }
</style>

<div class="cmd-page">
  <!-- Header + étapes -->
  <header class="cmd-hdr">
    <div class="cmd-brand">
      <div class="cmd-brand-icon">📋</div>
      <div>
        <div class="cmd-brand-name">COMMANDE</div>
        <div class="cmd-brand-sub">Renseignez vos informations</div>
      </div>
    </div>

    <div class="cmd-steps">
      <div class="cmd-step">
        <div class="cmd-step-n">1</div>
        <span class="cmd-step-lbl">Personnalisation</span>
      </div>
      <div class="cmd-step-line"></div>
      <div class="cmd-step">
        <div class="cmd-step-n">2</div>
        <span class="cmd-step-lbl">Récapitulatif</span>
      </div>
      <div class="cmd-step-line"></div>
      <div class="cmd-step on">
        <div class="cmd-step-n">3</div>
        <span class="cmd-step-lbl">Commande</span>
      </div>
    </div>

    <a href="/pages/recapitulatif" class="cmd-back">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
      Retour
    </a>
  </header>

  <!-- Corps -->
  <div class="cmd-body" id="cmd-body">
    <div>
      <h1 class="cmd-title">Vos informations</h1>
      <p class="cmd-subtitle">Renseignez vos coordonnées pour finaliser votre commande.</p>

      <form class="cmd-form" id="cmd-form">
        <div class="cmd-field-group">
          <div class="cmd-group-title">Coordonnées</div>
          <div class="cmd-row">
            <div class="cmd-field">
              <label>Prénom <span class="req">*</span></label>
              <input type="text" name="prenom" required>
            </div>
            <div class="cmd-field">
              <label>Nom <span class="req">*</span></label>
              <input type="text" name="nom" required>
            </div>
          </div>
          <div class="cmd-field">
            <label>Email <span class="req">*</span></label>
            <input type="email" name="email" required>
          </div>
          <div class="cmd-field">
            <label>Téléphone <span class="req">*</span></label>
            <input type="tel" name="telephone" required>
          </div>
          <div class="cmd-field">
            <label>Entreprise / Organisation (facultatif)</label>
            <input type="text" name="entreprise">
          </div>
        </div>

        <div class="cmd-field-group">
          <div class="cmd-group-title">Votre demande</div>
          <div class="cmd-field">
            <label>Message ou précisions (facultatif)</label>
            <textarea name="message" placeholder="Indiquez toute précision utile pour votre commande…"></textarea>
          </div>
        </div>
      </form>
    </div>

    <!-- Récap commande -->
    <aside class="cmd-summary">
      <div class="cmd-summary-title">Votre commande</div>
      <div id="cmd-items"></div>
      <div class="cmd-line-total">
        <span>Total</span>
        <span><span id="cmd-total">—</span> <span class="cmd-total-vat">TTC</span></span>
      </div>
      <button class="cmd-submit" id="cmd-submit" type="button" onclick="submitOrder()">
        Commander
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z"/></svg>
      </button>
      <button class="cmd-cancel" type="button" onclick="cancelOrder()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
        Annuler
      </button>
    </aside>
  </div>
</div>

<script>
  // URL de base du backend NestJS (déployé sur Railway)
  const API_BASE = "https://customizer-backend-production-6ed2.up.railway.app/api";

  // Variants Shopify pour le panier natif (produits à prix fixe).
  // coins n'a pas de variant : il passe par une demande de devis.
  const CONF_VARIANTS = {
    sweatshirt:       47843224944803,
    tshirt:           47843225338019,
    tshirt_polyester: 47843228319907,
    drapeaux:         47843229270179,
    patches:          47843295428771
  };

  function money(val) {
    return (Number(val) || 0).toFixed(2).replace('.', ',') + ' €';
  }
  function esc(s) {
    return String(s == null ? '' : s)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  function getCart() {
    try { return JSON.parse(sessionStorage.getItem('conf_cart')) || []; }
    catch (e) { return []; }
  }

  (function renderSummary() {
    const items = getCart();
    const el = document.getElementById('cmd-items');
    if (!items.length) {
      el.innerHTML = `<p style="color:#888;font-size:13px;padding:10px 0;">Votre panier est vide. <a href="/pages/configurateur">Retour au configurateur</a></p>`;
      document.getElementById('cmd-total').textContent = money(0);
      document.getElementById('cmd-submit').disabled = true;
      return;
    }
    let total = 0;
    el.innerHTML = items.map(item => {
      const line = (Number(item.price) || 0) * (item.qty || 1);
      total += line;
      const img = item.img
        ? `<img class="cmd-sum-img" src="${esc(item.img)}" alt="">`
        : `<div class="cmd-sum-img"><svg width="22" height="22" viewBox="0 0 24 24" fill="#c9ccd1"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2z"/></svg></div>`;
      return `
        <div class="cmd-sum-item">
          ${img}
          <div class="cmd-sum-info">
            <div class="cmd-sum-name">${esc(item.name)}</div>
            <div class="cmd-sum-qty">Qté : ${item.qty || 1}</div>
          </div>
          <div class="cmd-sum-price">${money(line)}</div>
        </div>`;
    }).join('');
    document.getElementById('cmd-total').textContent = money(total);
  })();

  function cancelOrder() {
    if (!confirm('Voulez-vous vraiment annuler votre commande ? Votre panier sera vidé.')) return;
    // Annuler : vider le panier et retourner au configurateur
    try {
      sessionStorage.removeItem('conf_cart');
      sessionStorage.removeItem('conf_order');
    } catch (e) {}
    window.location.href = '/pages/configurateur';
  }

  /* Construit les line items Shopify à partir du panier local.
     Chaque item est rattaché à son variant via productType. Les propriétés
     de personnalisation (couleur, taille, aperçu) sont jointes à la ligne.
     Les coins n'ont pas de variant : ils passent par une demande de devis
     et sont ignorés ici. */
  function buildShopifyItems(cart) {
    const items = [];
    const skipped = [];
    cart.forEach(it => {
      const variantId = CONF_VARIANTS[it.productType];
      if (!variantId) { skipped.push(it); return; }

      const properties = {};
      if (it.color) properties['Détails'] = it.color;
      if (it.size)  properties['Taille'] = it.size;
      if (it.img)   properties['Aperçu'] = it.img;

      items.push({
        id: variantId,
        quantity: Math.max(1, parseInt(it.qty, 10) || 1),
        properties: Object.keys(properties).length ? properties : undefined
      });
    });
    return { items, skipped };
  }

  async function submitOrder() {
    const form = document.getElementById('cmd-form');
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const cart = getCart();
    if (!cart.length) { alert('Votre panier est vide.'); return; }

    const { items, skipped } = buildShopifyItems(cart);

    // Panier composé uniquement d'articles sur devis (coins) : pas de checkout.
    if (!items.length) {
      alert("Votre panier ne contient que des articles sur devis (coins). " +
            "Utilisez le bouton « Faire une demande de devis » depuis le configurateur.");
      return;
    }
    if (skipped.length) {
      const ok = confirm(
        skipped.length + " article(s) sur devis (coins) ne peuvent pas être payés en ligne " +
        "et seront retirés. Continuer avec les " + items.length + " autre(s) article(s) ?"
      );
      if (!ok) return;
    }

    const btn = document.getElementById('cmd-submit');
    if (btn) { btn.disabled = true; btn.textContent = 'Redirection…'; }

    try {
      // 1) On repart d'un panier Shopify propre (évite les doublons au retour).
      await fetch('/cart/clear.js', { method: 'POST' });

      // 2) Ajout de tous les articles au panier natif Shopify.
      const res = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: items })
      });
      if (!res.ok) {
        const txt = await res.text().catch(() => '');
        throw new Error('Ajout au panier Shopify échoué (' + res.status + '). ' + txt);
      }

      // 3) On redirige vers le checkout Shopify SANS purger le design :
      //    tant que le paiement n'est pas confirmé, le client doit pouvoir
      //    revenir en arrière et retrouver son panier. La réinitialisation
      //    se fait uniquement après un paiement réussi, sur la page de
      //    remerciement Shopify (voir snippet de purge post-paiement).
      window.location.href = '/checkout';
    } catch (err) {
      console.error('Erreur commande :', err);
      if (btn) { btn.disabled = false; btn.textContent = 'Commander'; }
      alert("Une erreur est survenue lors du passage au paiement.\n" + err.message);
    }
  }
</script>

{% schema %}
{
  "name": "Commande",
  "settings": []
}
{% endschema %}
