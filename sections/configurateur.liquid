    /* ── Zoom ── */
    function zoom(d) {
      zl = Math.min(200, Math.max(50, zl + d));
      document.getElementById('zlvl').textContent = zl + '%';
      applyZoom();
    }

    function applyZoom() {
      // Textile : .cv-single-view (combiné avec l'échelle de taille)
      const singleView = document.querySelector('.cv-single-view');
      if (singleView) {
        const currentSize = singleView.dataset.sizeScale || '1';
        const combined = (zl / 100) * parseFloat(currentSize);
        singleView.style.transform = `scale(${combined})`;
        singleView.style.transformOrigin = 'center center';
        singleView.style.transition = 'transform 0.2s ease';
      }
      // Autres produits
      document.querySelectorAll('.cv-view, .coins-canvas-circle, .flag-stage, .coin-stage').forEach(v => {
        v.style.transform = `scale(${zl/100})`;
        v.style.transformOrigin = 'center center';
      });
    }

    function resetZoom() {
      zl = 100;
      document.getElementById('zlvl').textContent = '100%';
      applyZoom();
      // Remettre les autres à zéro aussi
      document.querySelectorAll('.cv-view, .coins-canvas-circle, .flag-stage, .coin-stage').forEach(v => { v.style.transform = ''; });
    }

    /* ── File upload ── */
    // Registre des URLs Cloudinary (une par zone) une fois l'upload backend terminé
    window.CLOUDINARY_URLS = window.CLOUDINARY_URLS || {};

    function doUpload(e, zone) {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = ev => {
        const original = ev.target.result;

        // Demande au client s'il veut supprimer l'arrière-plan (détourage local).
        // Le module résout avec l'image d'origine OU la version détourée transparente.
        const decide = (window.ConfBgRemoval && typeof window.ConfBgRemoval.ask === 'function')
          ? window.ConfBgRemoval.ask(original)
          : Promise.resolve(original);

        decide.then(function (src) {
          // Persister ce design pour le retrouver après un rechargement
          saveUpload(zone, src);
          // Applique l'image dans l'interface (affichage instantané via data URL)
          applyUpload(zone, src);

          // Upload sur une manche : on pivote vers elle pour que le client
          // voie ce qu'il vient de poser. (Uniquement à l'upload — pas à la
          // restauration, sinon le vêtement tournerait seul au rechargement.)
          if ((zone === 'sl' || zone === 'sr') &&
              typeof window.showSleeve === 'function') {
            window.showSleeve(zone);
          }

          // En arrière-plan : upload vers Cloudinary via le backend (production).
          // On envoie l'image RÉELLEMENT retenue (détourée si le client a choisi
          // de retirer le fond, sinon l'originale). N'empêche jamais l'affichage.
          if (window.ConfAPI) {
            const uploadFile = (src === original)
              ? file                                  // inchangée : garde le fichier d'origine
              : dataUrlToFile(src, file.name);        // détourée : PNG transparent
            window.ConfAPI.uploadLogo(uploadFile)
              .then(res => {
                if (res && res.url) {
                  window.CLOUDINARY_URLS[zone] = res.url;
                  console.log('☁️ Uploadé sur Cloudinary (' + zone + ') :', res.url);
                }
              })
              .catch(err => console.warn('Upload Cloudinary échoué (' + zone + ') :', err.message));
          }
        });
      };
      reader.readAsDataURL(file);
    }

    /* Convertit un dataURL (ex. PNG détouré) en objet File pour l'upload backend. */
    function dataUrlToFile(dataUrl, name) {
      const parts = dataUrl.split(',');
      const mime = (parts[0].match(/:(.*?);/) || [null, 'image/png'])[1];
      const bin = atob(parts[1]);
      const arr = new Uint8Array(bin.length);
      for (let i = 0; i < bin.length; i++) arr[i] = bin.charCodeAt(i);
      // Nom en .png car le détourage produit du PNG transparent.
      const baseName = (name || 'design').replace(/\.[^.]+$/, '') + '.png';
      return new File([arr], baseName, { type: mime });
    }

    /* ── Persistance des designs uploadés (image + taille/position) ── */
    function getUploads() {
      try { return JSON.parse(sessionStorage.getItem('conf_uploads')) || {}; }
      catch (e) { return {}; }
    }
    // Sauvegarde l'image d'une zone (conserve la géométrie déjà enregistrée si elle existe)
    function saveUpload(zone, src) {
      const u = getUploads();
      const prev = (u[zone] && typeof u[zone] === 'object') ? u[zone] : {};
      u[zone] = { src: src, geo: prev.geo || null };
      // Mémorise le produit courant : au reload, on doit restaurer ces uploads
      // sur le BON produit (ex. t-shirt polyester), pas sur le sweatshirt par défaut.
      u._product = currentProductType;
      try { sessionStorage.setItem('conf_uploads', JSON.stringify(u)); } catch (e) {}
    }
    // Sauvegarde la taille/position (left/top/width) d'un logo pour une zone
    function saveUploadGeo(zone, geo) {
      const u = getUploads();
      if (!u[zone]) return;                 // pas d'image pour cette zone : rien à faire
      if (typeof u[zone] === 'string') u[zone] = { src: u[zone] };
      u[zone].geo = geo;
      try { sessionStorage.setItem('conf_uploads', JSON.stringify(u)); } catch (e) {}
    }
    function removeUpload(zone) {
      const u = getUploads();
      delete u[zone];
      try { sessionStorage.setItem('conf_uploads', JSON.stringify(u)); } catch (e) {}
    }

    // Réapplique tous les designs sauvegardés après un chargement de page
    function restoreUploads() {
      const u = getUploads();
      Object.keys(u).forEach(zone => {
        if (zone === '_product') return; // clé technique, pas une zone de logo
        const entry = u[zone];
        const src = (typeof entry === 'string') ? entry : (entry && entry.src);
        const geo = (entry && typeof entry === 'object') ? entry.geo : null;
        if (src) {
          applyUpload(zone, src);
          if (geo) applyUploadGeo(zone, geo);
        }
      });
    }

    // Applique une géométrie sauvegardée au(x) logo(s) d'une zone
    function applyUploadGeo(zone, geo) {
      // Map zone -> id(s) du/des logo(s) déplaçable(s)
      const ids = {
        'f': ['logo-f'],
        'fr': ['logo-fr'],
        'b': ['logo-b'],
        'sl': ['logo-sl', 'logo-sl-face'],
        'sr': ['logo-sr', 'logo-sr-face'],
        'c': ['patch-logo'],
        'coin-recto': ['coin-logo-recto'],
        'coin-verso': ['coin-logo-verso'],
        'flag-recto': ['flag-logo-recto'],
        'flag-verso': ['flag-logo-verso']
      }[zone] || [];
      ids.forEach(id => {
        const el = document.getElementById(id);
        if (!el) return;
        if (geo.left  != null) el.style.left  = geo.left;
        if (geo.top   != null) el.style.top   = geo.top;
        if (geo.width != null) el.style.width = geo.width;
      });
    }

    /* ── Application d'un design dans l'interface (partagé upload + restauration) ── */
    function applyUpload(zone, src) {
      {

        // Si c'est un upload de coin
        if (zone === 'c') {
          // Preview dans la sidebar
          const prev = document.getElementById('pc');
          const img  = document.getElementById('ic');
          const lbl  = document.getElementById('lc');
          if (prev && img) { img.src = src; prev.style.display = 'block'; }
          if (lbl) lbl.style.display = 'flex';
          
          // Afficher dans le canvas circulaire (logo déplaçable/redimensionnable)
          const coinsCanvas = document.getElementById('coins-canvas');
          const coinsPreviewImg = document.getElementById('coins-preview-img');
          const patchLogo = document.getElementById('patch-logo');
          if (coinsPreviewImg) coinsPreviewImg.src = src;
          if (patchLogo) patchLogo.style.display = 'block';
          if (coinsCanvas) {
            coinsCanvas.classList.add('has-image');
            // Masquer le placeholder
            const ph = coinsCanvas.querySelector('.coins-placeholder');
            if (ph) ph.style.display = 'none';
          }
          // Aucune contrainte de zone sur le patch : le client place son logo
          // librement. On rafraîchit juste la miniature du récap une fois
          // l'image chargée (ses dimensions sont alors connues).
          if (coinsPreviewImg) {
            coinsPreviewImg.addEventListener('load', function onceLoaded() {
              coinsPreviewImg.removeEventListener('load', onceLoaded);
              if (typeof updatePatchRecapThumb === 'function') updatePatchRecapThumb();
            });
          }
          // Recap - miniature : image du patch (forme + couleur) + logo positionné.
          updatePatchRecapThumb();

          return;
        }

        // Si c'est un upload de coin métallique (recto / verso)
        if (zone === 'coin-recto' || zone === 'coin-verso') {
          const face = zone === 'coin-recto' ? 'recto' : 'verso';

          // Logo déplaçable/redimensionnable sur la pièce
          const logo = document.getElementById('coin-logo-' + face);
          if (logo) {
            const limg = logo.querySelector('img');
            if (limg) limg.src = src;
            logo.style.display = 'block';
          }

          // Afficher le logo recto aussi sur la vue de côté (aperçu)
          if (face === 'recto') {
            const coteLogo = document.getElementById('coin-cote-logo');
            if (coteLogo) { coteLogo.src = src; coteLogo.style.display = 'block'; }
          }

          // Afficher le bouton Supprimer
          const removeBtn = document.getElementById('coin-remove-' + face);
          if (removeBtn) removeBtn.style.display = 'inline-block';

          // Vignette du récap : recto composé (disque + logo), temps réel.
          updateCoinRecapThumb();
          return;
        }

        // Si c'est un upload de drapeau (recto / verso)
        if (zone === 'flag-recto' || zone === 'flag-verso') {
          const wrap = document.getElementById(zone);
          if (wrap) {
            // Masquer les placeholders (3D + 2D)
            wrap.querySelectorAll('.flag-canvas-placeholder').forEach(ph => ph.style.display = 'none');
            // Mettre l'image dans toutes les zones design (3D déplaçable + 2D codé)
            wrap.querySelectorAll('.flag-design-img').forEach(img => { img.src = src; img.style.display = 'block'; });
          }
          // Afficher le logo déplaçable (vue 3D)
          const face = zone === 'flag-recto' ? 'recto' : 'verso';
          const dragLogo = document.getElementById('flag-logo-' + face);
          if (dragLogo) dragLogo.style.display = 'block';

          // Afficher le bouton Supprimer
          const flagRemoveBtn = document.getElementById('flag-remove-' + face);
          if (flagRemoveBtn) flagRemoveBtn.style.display = 'inline-block';
          // Miniature du récap (recto uniquement) : drapeau + logo positionné.
          if (zone === 'flag-recto') {
            updateFlagRecapThumb();
          }
          return;
        }

        // FACE : logo cœur et texte sont exclusifs. Ajouter un logo retire le texte.
        if (zone === 'f' || zone === 'fr') {
          if (typeof removeText === 'function') removeText(zone);
          if (typeof setTextEnabled === 'function') setTextEnabled(zone, false);
        }

        // Sidebar preview (textiles)
        const prev = document.getElementById('p' + zone);
        const img  = document.getElementById('i' + zone);
        const lbl  = document.getElementById('l' + zone);
        if (prev && img) { img.src = src; prev.style.display = 'block'; }
        if (lbl)          lbl.style.display = 'flex';

        // SVG overlay
        const ov = document.getElementById('ov-' + zone);
        if (ov) { ov.setAttribute('href', src); ov.style.display = 'block'; }

        // Logos manches déplaçables. Chaque manche a désormais SA vue : le
        // profil est le même retourné en miroir, et [data-side] n'affiche que
        // le côté courant. La manche droite n'était pas rendue du tout
        // auparavant — un upload dessus restait invisible.
        if (zone === 'sl' || zone === 'sr') {
          const logo = document.getElementById('logo-' + zone);
          if (logo) {
            const limg = logo.querySelector('img');
            if (limg) limg.src = src;
            logo.style.display = 'block';
          }
          // Le logo "-face" conserve l'asset (compat récap/export) mais reste
          // masqué : les manches ne s'affichent plus en vue de face.
          const logoFace = document.getElementById('logo-' + zone + '-face');
          if (logoFace) {
            const limg2 = logoFace.querySelector('img');
            if (limg2) limg2.src = src;
            logoFace.style.display = 'none';
          }
          const rcS = document.getElementById('rc-sleeves');
          if (rcS) rcS.style.display = 'flex';

          // Placement auto dans la zone de la manche concernée.
          placeLogoInZone(zone);

          // La rotation vers la bonne manche est déclenchée par doUpload
          // (showSleeve), qui passe en vue de côté puis pivote. On ne bascule
          // pas ici : applyUpload sert aussi à la RESTAURATION au rechargement,
          // et le vêtement se mettrait à tourner tout seul.
        }

        // Logos poitrine déplaçables (vue de face) + bascule auto vers la face.
        // 'f' = cœur (gauche du porteur), 'fr' = poitrine droite : même
        // traitement, seul l'id du calque change.
        if (zone === 'f' || zone === 'fr') {
          const logo = document.getElementById('logo-' + zone);
          if (logo) {
            const limg = logo.querySelector('img');
            if (limg) {
              limg.src = src;
              // Placement auto dans la zone dès que l'image est chargée (ratio connu).
              limg.onload = function () { placeLogoInZone(zone); };
            }
            logo.style.display = 'block';
          }
          placeLogoInZone(zone);
          // Aperçu temps réel dans la vignette récap
          updateRecapThumbLogo();
          // Basculer vers la vue de face pour positionner le logo
          const faceBtn = document.querySelector('.vt[onclick*="face"]');
          if (faceBtn && typeof selView === 'function') {
            selView(faceBtn, 'face');
          }
        }

        // Logo dos déplaçable sur le produit + bascule automatique vers la vue de dos
        if (zone === 'b') {
          const logo = document.getElementById('logo-b');
          if (logo) {
            const limg = logo.querySelector('img');
            if (limg) {
              limg.src = src;
              limg.onload = function () { placeLogoInZone('b'); };
            }
            logo.style.display = 'block';
          }
          placeLogoInZone('b');
          // Basculer vers la vue de dos pour que le client positionne le logo
          const dosBtn = document.querySelector('.vt[onclick*="dos"]');
          if (dosBtn && typeof selView === 'function') {
            selView(dosBtn, 'dos');
          }
        }

        // Recap rows
        if (zone === 'f') {
          document.getElementById('rc-img-f').src = src;
          document.getElementById('rc-front').style.display = 'flex';
        }
        if (zone === 'b') {
          document.getElementById('rc-img-b').src = src;
          document.getElementById('rc-back').style.display = 'flex';
        }
      }
    }

    function rmUp(zone) {
      // Retirer de la persistance
      removeUpload(zone);

      // Si c'est un coin
      if (zone === 'c') {
        const prev = document.getElementById('pc');
        const img  = document.getElementById('ic');
        const lbl  = document.getElementById('lc');
        const input = document.getElementById('uc');
        
        if (img) img.src = '';
        if (prev) prev.style.display = 'none';
        if (lbl) lbl.style.display = 'none';
        if (input) input.value = '';
        
        // Cacher dans le canvas (logo déplaçable) + réafficher le placeholder
        const coinsCanvas = document.getElementById('coins-canvas');
        const coinsPreviewImg = document.getElementById('coins-preview-img');
        const patchLogo = document.getElementById('patch-logo');
        if (coinsCanvas) {
          coinsCanvas.classList.remove('has-image');
          const ph = coinsCanvas.querySelector('.coins-placeholder');
          if (ph) ph.style.display = '';
        }
        if (coinsPreviewImg) coinsPreviewImg.src = '';
        if (patchLogo) {
          patchLogo.style.display = 'none';
          patchLogo.style.left = '15%';
          patchLogo.style.top = '15%';
          patchLogo.style.width = '70%';
          patchLogo.style.height = '';
        }
        // Réinitialiser la miniature du récap
        const recapThumb = document.getElementById('coins-recap-thumb');
        if (recapThumb) {
          recapThumb.innerHTML = `
            <svg width="60" height="60" viewBox="0 0 24 24" fill="#ccc">
              <circle cx="12" cy="12" r="10" fill="none" stroke="#ccc" stroke-width="2"/>
              <path d="M12 8v8M8 12h8" stroke="#ccc" stroke-width="2"/>
            </svg>`;
        }

        return;
      }
      
      // Textiles
      ['p','i','l'].forEach(pfx => {
        const el = document.getElementById(pfx + zone);
        if (!el) return;
        if (pfx === 'i') el.src = '';
        else if (pfx === 'p') el.style.display = 'none';
        else el.style.display = 'none';
      });
      const input = document.getElementById('u' + zone);
      if (input) input.value = '';
      const ov = document.getElementById('ov-' + zone);
      if (ov) { ov.removeAttribute('href'); ov.style.display = 'none'; }

      // Cacher le(s) logo(s) déplaçable(s) correspondant(s) sur le produit
      ['logo-' + zone, 'logo-' + zone + '-face'].forEach(id => {
        const logo = document.getElementById(id);
        if (logo) {
          const limg = logo.querySelector('img');
          if (limg) limg.src = '';
          logo.style.display = 'none';
        }
      });

      if (zone === 'f' || zone === 'fr') {
        if (zone === 'f') document.getElementById('rc-front').style.display = 'none';
        // Le logo est retiré : réautoriser l'ajout de texte sur CETTE zone.
        if (typeof setTextEnabled === 'function') setTextEnabled(zone, true);
      }
      if (zone === 'b') document.getElementById('rc-back').style.display = 'none';
      if (zone === 'sl' || zone === 'sr') {
        const slSrc = document.getElementById('isl')?.src;
        const srSrc = document.getElementById('isr')?.src;
        if (!slSrc && !srSrc) document.getElementById('rc-sleeves').style.display = 'none';
      }
      // Mettre à jour l'aperçu temps réel de la vignette récap (logo cœur)
      updateRecapThumbLogo();
      // Réafficher les zones guides dont le logo a été retiré.
      if (typeof refreshZoneGuides === 'function') refreshZoneGuides();
    }

    /* ══════════════ TEXTE PERSONNALISÉ (textiles) ══════════════
       La logique d'édition (panneau, polices, formes) est dans le module
       conf-text-editor.js. Ici on garde uniquement :
       - l'exclusivité FACE (texte <-> logo cœur),
       - le passage de la zone pointillée en mode HORIZONTAL pour le texte,
       - le clamp du texte DANS sa zone. */

    // Active/désactive la zone d'upload logo cœur (exclusivité face).
    function setUploadEnabled(zone, enabled) {
      if (zone !== 'f') return;
      var uz = document.getElementById('uz-f');
      if (!uz) return;
      uz.style.pointerEvents = enabled ? '' : 'none';
      uz.style.opacity = enabled ? '' : '0.4';
    }
    function setTextEnabled(zone, enabled) { refreshTextButton(); }

    /* Active/désactive le bouton « Ajouter un texte » selon la vue courante.
       Le bouton vit dans #txt-add-btns (un seul bouton + sélecteur
       d'emplacement) ; #txt-add-btn est l'ancien id, conservé en repli.
       Plus de désactivation liée au logo cœur : chaque emplacement est
       indépendant, et l'exclusivité logo/texte se règle zone par zone au
       moment de l'insertion. */
    function refreshTextButton() {
      var btn = document.querySelector('#txt-add-btns .txt-add-btn') ||
                document.getElementById('txt-add-btn');
      if (!btn) return;
      var layer = document.getElementById('logo-layer');
      var view = layer ? layer.getAttribute('data-view') : 'face';
      var onSleeve = (view === 'cote');
      btn.disabled = onSleeve;
      btn.title = onSleeve ? 'Le texte n\'est pas disponible sur les manches' : '';
    }
    window.refreshTextButton = refreshTextButton;

    /* Passe la zone pointillée en mode HORIZONTAL (bandeau) pour le texte, ou
       la remet dans sa forme d'origine. Mémorise le style d'origine. */
    /* Taille de police maximale du texte personnalisé (px CSS).
       Plafond atelier : au-delà, le rendu d'impression n'est plus garanti.
       Exposée sur window : conf-text-editor.js s'en sert pour borner l'état
       du panneau, et le curseur #txt-size-range porte la même valeur en max. */
    var MAX_TEXT_SIZE = 28;
    window.MAX_TEXT_SIZE = MAX_TEXT_SIZE;

    var _zoneOrigStyle = {};
    var TEXT_ZONE_HORIZ = {
      // Bandeau horizontal centré, adapté au texte (plus étroit).
      'f':  { left: 44, top: 31, width: 22, height: 9 },
      // Poitrine droite du porteur : miroir de 'f' (44 -> 100-44-22 = 34).
      'fr': { left: 34, top: 31, width: 22, height: 9 },
      'b':  { left: 36, top: 27, width: 28, height: 11 }
    };
    function setTextZoneMode(zone, on) {
      var zid = (zone === 'f' || zone === 'fr' || zone === 'b') ? ('zone-' + zone) : null;
      if (!zid) return;
      var zoneEl = document.getElementById(zid);
      if (!zoneEl) return;
      if (on) {
        if (!_zoneOrigStyle[zone]) {
          _zoneOrigStyle[zone] = { left: zoneEl.style.left, top: zoneEl.style.top,
            width: zoneEl.style.width, height: zoneEl.style.height };
        }
        var h = TEXT_ZONE_HORIZ[zone];
        zoneEl.style.left = h.left + '%'; zoneEl.style.top = h.top + '%';
        zoneEl.style.width = h.width + '%'; zoneEl.style.height = h.height + '%';
        zoneEl.classList.add('text-mode');
        // Centre le texte dans la zone.
        var el = document.getElementById('text-' + zone);
        if (el) {
          el.style.left = h.left + '%';
          el.style.top = (h.top + 1) + '%';
          el.style.width = h.width + '%';
          el.style.textAlign = 'center';
        }
      } else {
        var o = _zoneOrigStyle[zone];
        if (o) { zoneEl.style.left = o.left; zoneEl.style.top = o.top;
          zoneEl.style.width = o.width; zoneEl.style.height = o.height; }
        zoneEl.classList.remove('text-mode');
      }
      if (typeof refreshZoneGuides === 'function') refreshZoneGuides();
    }
    window.setTextZoneMode = setTextZoneMode;

    /* Contraint le texte à rester DANS sa zone horizontale.
       1) RÉDUIT la police si le texte est plus large/haut que la zone (il ne
          déborde donc jamais, comme sur CustomInk : le texte rapetisse au lieu
          de sortir). 2) BORNE ensuite la position dans la zone. */
    function clampTextToZone(zone) {
      var h = TEXT_ZONE_HORIZ[zone];
      var el = document.getElementById('text-' + zone);
      var layer = document.getElementById('logo-layer');
      if (!h || !el || !layer) return;

      var lb = layer.getBoundingClientRect();
      if (!lb.width || !lb.height) return;

      // Dimensions de la zone en pixels écran.
      var zoneW = (h.width / 100) * lb.width;
      var zoneH = (h.height / 100) * lb.height;

      // 1) Ajuste la taille de police pour tenir dans la zone (largeur ET
      //    hauteur). On part de la taille demandée et on réduit si nécessaire.
      var cur = parseFloat(window.getComputedStyle(el).fontSize) || 20;
      var guard = 0;
      // Réduction : tant que le texte déborde, on rapetisse (min 8px).
      while (guard++ < 40) {
        var eb = el.getBoundingClientRect();
        if ((eb.width <= zoneW && eb.height <= zoneH) || cur <= 8) break;
        cur = Math.max(8, cur - 1);
        el.style.fontSize = cur + 'px';
      }
      // Plafond atelier : quelle que soit la place disponible dans la zone, la
      // police ne dépasse pas MAX_TEXT_SIZE. Appliqué ici car cette fonction
      // est le passage obligé du panneau ET du redimensionnement à la souris —
      // borner le seul curseur laisserait la poignée de resize le contourner.
      if (cur > MAX_TEXT_SIZE) {
        cur = MAX_TEXT_SIZE;
        el.style.fontSize = cur + 'px';
      }

      // Agrandissement : si on avait trop réduit et qu'il reste de la place,
      // on regrossit jusqu'à la taille voulue (sans jamais déborder).
      var wanted = Math.min(
        parseFloat(el.getAttribute('data-wanted-size')) || cur,
        MAX_TEXT_SIZE
      );
      while (guard++ < 80 && cur < wanted) {
        el.style.fontSize = (cur + 1) + 'px';
        var eb2 = el.getBoundingClientRect();
        if (eb2.width > zoneW || eb2.height > zoneH) { el.style.fontSize = cur + 'px'; break; }
        cur += 1;
      }

      // 2) Borne la position dans la zone.
      var ebf = el.getBoundingClientRect();
      var wPct = (ebf.width / lb.width) * 100;
      var hPct = (ebf.height / lb.height) * 100;
      var left = parseFloat(el.style.left); if (isNaN(left)) left = h.left;
      var top = parseFloat(el.style.top); if (isNaN(top)) top = h.top;
      var minL = h.left, maxL = h.left + h.width - wPct;
      var minT = h.top, maxT = h.top + h.height - hPct;
      if (maxL < minL) maxL = minL;
      if (maxT < minT) maxT = minT;
      el.style.left = Math.max(minL, Math.min(maxL, left)) + '%';
      el.style.top = Math.max(minT, Math.min(maxT, top)) + '%';
    }
    window.clampTextToZone = clampTextToZone;

    /* ── Coins functions ── */
    function selectShape(el) {
      document.querySelectorAll('.coins-shape-card').forEach(s => s.classList.remove('active'));
      el.classList.add('active');
      const shapeName = el.querySelector('span').textContent;
      const shape = el.dataset.shape;

      // La forme est portée par la CLASSE shape-* (lue par patchShapeName()),
      // puis rendue par l'IMAGE PNG (updatePatchShapeImg applique aussi le ratio).
      const canvas = document.getElementById('coins-canvas');
      if (canvas && shape) {
        canvas.classList.remove('shape-rond', 'shape-carre', 'shape-rectangle', 'shape-blason');
        canvas.classList.add('shape-' + shape);
      }

      // Recalcule l'image du patch (forme + couleur, repli teinté) + l'aspect-ratio.
      if (typeof updatePatchShapeImg === 'function') updatePatchShapeImg();

      // Mettre à jour le récap
      const recapShape = document.getElementById('coins-recap-shape');
      if (recapShape) recapShape.textContent = shapeName;

      // La vignette du récap doit suivre la nouvelle forme.
      if (typeof updatePatchRecapThumb === 'function') updatePatchRecapThumb();
    }

    // Couleur de fond du patch
    function selectPatchColor(el, hex, name) {
      document.querySelectorAll('.patch-color-sw').forEach(s => s.classList.remove('active'));
      el.classList.add('active');

      // Couleur courante du patch (hex + slug de fichier). Le rendu se fait via
      // l'IMAGE PNG patch-{forme}-{slug}.png (ou l'image blanche teintée en repli).
      window.currentPatchHex = hex;
      window.currentPatchSlug = (typeof patchHexToSlug === 'function') ? patchHexToSlug(hex) : 'noir';

      // On conserve --patch-color / backgroundColor pour compat (capture lit le hex).
      const canvas = document.getElementById('coins-canvas');
      if (canvas) {
        canvas.style.setProperty('--patch-color', hex);
      }

      // Recalcule l'image du patch (vraie image colorée sinon blanc teinté).
      if (typeof updatePatchShapeImg === 'function') updatePatchShapeImg();

      // Met à jour la vignette du récap (image + logo positionné).
      if (typeof updatePatchRecapThumb === 'function') updatePatchRecapThumb();

      // Ajouter/mettre à jour la ligne "Couleur" dans le récap
      let recapColor = document.getElementById('coins-recap-color');
      if (recapColor) {
        recapColor.textContent = name;
      }

      // Persiste la couleur du patch : restaurée au reload.
      try { sessionStorage.setItem('conf_patch_color', JSON.stringify({ hex: hex, name: name })); } catch (e) {}

      console.log('🎨 Couleur du patch:', name, hex);
    }

    function selectCoinSize(el) {
      // Gère les DEUX types de boutons taille : .coin-size-card (mm, texte direct)
      // et .coins-size-card (cm, avec <p>). On retire l'active des deux familles.
      document.querySelectorAll('.coin-size-card, .coins-size-card').forEach(s => s.classList.remove('active'));
      el.classList.add('active');

      // Libellé : <p> si présent (cartes cm), sinon le texte du bouton (cartes mm).
      var pEl = el.querySelector('p');
      var sizeName = (pEl ? pEl.textContent : el.textContent).trim();
      var sizeData = el.getAttribute('data-size') || sizeName;

      // Mettre à jour le récap (les deux ids possibles selon le layout).
      var recapSize = document.getElementById('coins-recap-size') || document.getElementById('coin-recap-size');
      if (recapSize) recapSize.textContent = sizeName;

      // Redimensionne le canvas 2D si des classes de taille existent (layout cm).
      var canvas = document.getElementById('coins-canvas');
      if (canvas && /cm$/.test(sizeData)) {
        canvas.classList.remove('size-6cm','size-7cm','size-8cm','size-9cm','size-10cm','size-8x6cm','size-10x7-5cm');
        canvas.classList.add('size-' + sizeData.replace(/\./g, '-'));
      }
      // Ajuste l'échelle visuelle du rendu (2D/3D) pour les tailles en mm.
      applyCoinSizeScale(sizeData);

      console.log('📏 Taille coin :', sizeName, '(' + sizeData + ')');
    }

    /* Échelle visuelle du coin selon le diamètre en mm (aperçu 2D et 3D).
       25mm = référence (1.0) ; augmente proportionnellement jusqu'à 50mm. */
    function applyCoinSizeScale(sizeData) {
      var mm = parseInt(String(sizeData), 10);
      if (isNaN(mm)) return;
      // Échelle douce : 25->0.85, 30->0.9, 38->1.0, 50->1.15 (bornée).
      var scale = Math.max(0.78, Math.min(1.2, 0.5 + mm / 42));
      // Cible chaque disque/aperçu de coin individuellement (recto, verso, côté)
      // + le canvas 2D circulaire, pour un rendu proportionnel à la taille.
      var sel = '.coin-disc, .coin-edge, #coins-canvas, .coins-canvas-circle';
      document.querySelectorAll(sel).forEach(function (elm) {
        elm.style.transform = 'scale(' + scale.toFixed(3) + ')';
        elm.style.transformOrigin = 'center center';
        elm.style.transition = 'transform .2s ease';
      });
    }

    function selectFabrication(el) {
      document.querySelectorAll('.conf-fabrication-option').forEach(f => f.classList.remove('active'));
      el.classList.add('active');
      const radio = el.querySelector('input[type="radio"]');
      if (radio) radio.checked = true;
      const typeName = el.querySelector('strong').textContent;
      console.log('Fabrication sélectionnée:', el.dataset.fabrication);
      
      // Mettre à jour le récap
      const recapType = document.getElementById('coins-recap-type');
      if (recapType) recapType.textContent = typeName;
    }

    function switchCoinsView(view) {
      // Supprimer la classe 'on' de tous les onglets
      document.querySelectorAll('.vtabs .vt').forEach(t => t.classList.remove('on'));
      
      // Ajouter la classe 'on' à l'onglet cliqué
      event.target.classList.add('on');
      
      console.log('Vue coins:', view);
      
      // TODO: Implémenter vraiment les différentes vues (2D vs réel)
      // Pour l'instant, juste changer l'apparence de l'onglet
    }

    /* ── Quantity management for Coins ── */
    function changeQty(delta) {
      const input = document.getElementById('coin-qty-input');
      if (!input) return;
      
      let currentQty = parseInt(input.value) || 20;
      let newQty = currentQty + delta;
      
      // Minimum 20 unités
      if (newQty < 20) newQty = 20;
      
      input.value = newQty;
      updateCoinPrice(newQty);
    }

    function handleQtyInput() {
      const input = document.getElementById('coin-qty-input');
      if (!input) return;
      
      let qty = parseInt(input.value) || 20;
      
      // Minimum 20 unités
      if (qty < 20) {
        qty = 20;
        input.value = qty;
      }
      
      updateCoinPrice(qty);
    }

    function updateCoinPrice(qty) {
      // Prix défini par l'admin (dashboard) ; repli sur window.PRICES.
      const pricePerUnit = window.prixUnitaire('patches');
      const totalHT = pricePerUnit * qty;
      const totalTTC = totalHT * 1.20; // TVA 20%
      
      // Mettre à jour l'affichage de la quantité
      const qtyDisplay = document.getElementById('coins-qty-display');
      if (qtyDisplay) {
        qtyDisplay.textContent = `à partir de (${qty} unités)`;
      }
      
      // Mettre à jour le prix total HT
      const totalPrice = document.getElementById('coins-total-price');
      if (totalPrice) {
        totalPrice.textContent = totalHT.toFixed(2) + ' €';
      }
      
      // Mettre à jour le prix total TTC
      const totalTtc = document.getElementById('coins-total-ttc');
      if (totalTtc) {
        totalTtc.textContent = totalTTC.toFixed(2) + ' € TTC';
      }
      
      console.log('Quantité:', qty, '| Prix total HT:', totalHT.toFixed(2), '€ | TTC:', totalTTC.toFixed(2), '€');
    }

    /* ── Contact for custom (PVC/Tissé) ── */
    function contactForCustom() {
      confAlert('Email : contact@customtextile.com\nTél : +33 1 23 45 67 89',
                { icon: 'info', title: 'Commande PVC ou Tissé' });
    }

    /* ── Init : charge les images de la couleur par défaut au démarrage ── */
    document.addEventListener('DOMContentLoaded', () => {
      updateProductImages();
    });

    /* ═══════════ Récapitulatif mobile : panneau repliable ═══════════
       Sur ≤768px, .recap est un panneau fixe en bas. Une poignée (barre) permet
       de le déplier pour voir le détail, puis de le replier. Repliée, seule la
       barre prix + « Ajouter au panier » reste visible. */
    (function () {
      var MOBILE = window.matchMedia('(max-width: 768px)');

      function toggleRecap() {
        var recap = document.querySelector('.recap');
        if (!recap || !MOBILE.matches) return;
        recap.classList.toggle('open');
      }
      // Exposé : le layout dynamique le rappelle après avoir réécrit le récap.
      window.toggleRecap = toggleRecap;

      /* (Ré)insère la poignée + les écouteurs. À rappeler après CHAQUE réécriture
         du récap (les produits coins/drapeaux/patchs remplacent recap.innerHTML,
         ce qui effaçait la poignée). */
      function setupRecapPanel() {
        var recap = document.querySelector('.recap');
        if (!recap) return;

        // Poignée : une seule, en tête du panneau.
        if (!recap.querySelector('.recap-handle')) {
          var handle = document.createElement('div');
          handle.className = 'recap-handle';
          handle.setAttribute('role', 'button');
          handle.setAttribute('aria-label', 'Afficher le récapitulatif');
          handle.addEventListener('click', toggleRecap);
          recap.insertBefore(handle, recap.firstChild);
        }

        // Un tap sur le bloc prix (replié) déplie le panneau. Vaut pour les deux
        // structures de récap (textile et coins/drapeaux/patchs).
        recap.querySelectorAll('.rp-price, .rp-total-section').forEach(function (p) {
          if (p.dataset.recapToggle === '1') return;
          p.dataset.recapToggle = '1';
          p.addEventListener('click', function () {
            if (MOBILE.matches && !recap.classList.contains('open')) toggleRecap();
          });
        });

        // Hauteur visible en position repliée = poignée + prix + boutons.
        // On la MESURE (le nb de boutons varie selon le produit) pour que rien
        // ne soit coupé sous le bas de l'écran.
        adjustRecapPeek(recap);
      }

      function adjustRecapPeek(recap) {
        if (!MOBILE.matches) return;
        var handle = recap.querySelector('.recap-handle');
        var price = recap.querySelector('.rp-price, .rp-total-section');
        var acts = recap.querySelector('.rp-acts, .rp-actions-coins');
        var peek = 0;
        [handle, price, acts].forEach(function (el) {
          if (el) peek += el.getBoundingClientRect().height;
        });
        peek += 14;                          // marge de sécurité

        // Si le bloc d'action est trop haut (3 boutons empilés) pour tenir dans
        // ~55% de l'écran, on ne garde en visible que le PREMIER bouton
        // (« Ajouter au panier ») ; les autres apparaîtront au déploiement.
        var maxPeek = window.innerHeight * 0.55;
        if (peek > maxPeek && acts) {
          var btns = acts.querySelectorAll('button');
          if (btns.length > 1) {
            var hHandle = handle ? handle.getBoundingClientRect().height : 0;
            var hPrice = price ? price.getBoundingClientRect().height : 0;
            var hFirst = btns[0].getBoundingClientRect().height;
            // padding vertical du conteneur d'actions (approx).
            peek = hHandle + hPrice + hFirst + 40;
          }
        }
        peek = Math.min(peek, maxPeek);
        if (peek > 0) recap.style.setProperty('--recap-peek', Math.round(peek) + 'px');
      }
      window.adjustRecapPeek = function () {
        var r = document.querySelector('.recap');
        if (r) adjustRecapPeek(r);
      };
      window.setupRecapPanel = setupRecapPanel;

      setupRecapPanel();

      // Repli au retour en desktop.
      MOBILE.addEventListener('change', function (e) {
        var recap = document.querySelector('.recap');
        if (!e.matches && recap) recap.classList.remove('open');
      });
    })();
  </script>
  </div><!-- /conf-app-root -->

