      <!-- PANNEAU D'ÉDITION TEXTE (remplace le sidebar, façon CustomInk) -->
      <div class="txt-panel" id="txt-panel" style="display:none">
        <div class="txt-panel-head">
          <button class="txt-panel-back" onclick="closeTextPanel(false)" title="Retour">‹</button>
          <span class="txt-panel-title">Modifier le texte</span>
          <button class="txt-panel-x" onclick="closeTextPanel(false)" title="Fermer">✕</button>
        </div>

        <div class="txt-panel-body">
          <!-- Champ texte (limité : un texte trop long déborde du vêtement) -->
          <input type="text" class="txt-panel-input" id="txt-panel-input" maxlength="25"
                 placeholder="Votre texte" oninput="onPanelTextChange()">
          <div class="txt-panel-count"><span id="txt-panel-count">0</span>/25 caractères</div>

          <!-- Style : gras / italique / souligné -->
          <div class="txt-panel-row txt-style-row">
            <span class="txt-panel-lbl">Style</span>
            <div class="txt-style-btns">
              <button type="button" class="txt-style-btn" id="txt-style-b" title="Gras"
                      onclick="toggleTextStyle('bold')" style="font-weight:800">B</button>
              <button type="button" class="txt-style-btn" id="txt-style-i" title="Italique"
                      onclick="toggleTextStyle('italic')" style="font-style:italic">I</button>
              <button type="button" class="txt-style-btn" id="txt-style-u" title="Souligné"
                      onclick="toggleTextStyle('underline')" style="text-decoration:underline">U</button>
            </div>
          </div>

          <!-- Taille du texte -->
          <div class="txt-panel-row txt-size-row">
            <span class="txt-panel-lbl">Taille</span>
            <!-- max = MAX_TEXT_SIZE (28) : plafond imposé par l'atelier. -->
            <input type="range" class="txt-size-range" id="txt-size-range"
                   min="12" max="28" step="1" value="20" oninput="onTextSizeChange()">
            <span class="txt-size-val" id="txt-size-val">20</span>
          </div>

          <!-- Change Font -->
          <div class="txt-panel-row" onclick="toggleFontPicker()">
            <span class="txt-panel-lbl">Police</span>
            <span class="txt-panel-val" id="txt-panel-font-val" style="font-size:16px">Arial</span>
            <span class="txt-panel-caret">›</span>
          </div>
          <div class="txt-font-picker" id="txt-font-picker" style="display:none">
            <input type="text" class="txt-font-search" id="txt-font-search" placeholder="Rechercher une police…" oninput="filterFonts()">
            <div class="txt-font-scroll" id="txt-font-scroll"></div>
          </div>

          <!-- Edit Color -->
          <div class="txt-panel-row">
            <span class="txt-panel-lbl">Couleur</span>
            <div class="txt-color-swatches" id="txt-color-swatches"></div>
          </div>

          <!-- Text Shape -->
          <div class="txt-panel-row" onclick="toggleShapePicker()">
            <span class="txt-panel-lbl">Forme du texte</span>
            <span class="txt-panel-val" id="txt-panel-shape-val">Normal</span>
            <span class="txt-panel-caret">›</span>
          </div>
          <div class="txt-shape-picker" id="txt-shape-picker" style="display:none">
            <div class="txt-shape-grid" id="txt-shape-grid"></div>
          </div>
        </div>

        <div class="txt-panel-foot">
          <button class="txt-panel-save" onclick="closeTextPanel(true)">✓ Enregistrer</button>
        </div>
      </div>
