    <!-- ══ CANVAS ══ -->
    <main class="canvas">
      <div class="cv-hdr">
        <h2 class="cv-title">Personnalisez votre article</h2>
        <p class="cv-sub">Visualisez votre design en temps réel</p>
        <div class="vtabs">
          <button class="vt on" onclick="selView(this,'face')">Vue de face</button>
          <button class="vt" onclick="selView(this,'dos')">Vue de dos</button>
          <button class="vt" onclick="selView(this,'cote')">Vue de côté</button>
        </div>

      </div>

            <div class="cv-wrap">
        <!-- Bascule gauche/droite : ancrée en haut à droite de l'aperçu, hors
             du flux pour ne pas décaler les onglets de vue. Visible seulement
             en vue de côté. Le profil droit est le profil gauche en miroir
             (le vêtement est symétrique) : aucune image supplémentaire. -->
        <div class="side-toggle" id="side-toggle" style="display:none">
          <button class="st-btn on" id="st-l" onclick="setSleeveSide('l')" title="Voir la manche gauche">
            <span class="st-ico">◀</span> Gauche
          </button>
          <button class="st-btn" id="st-r" onclick="setSleeveSide('r')" title="Voir la manche droite">
            Droite <span class="st-ico">▶</span>
          </button>
        </div>

        <div class="cv-canvas-row">
          <!-- UNE SEULE grande image qui change -->
          <div class="cv-single-view">
            <div class="mlbl">
              <div class="mline"></div>
              <span>5 cm</span>
            </div>
            
            <!-- Vue de face (visible par défaut) -->
            <img class="product-img-single on" id="view-face"
              src="{{ 'sweatshirt-face.png' | asset_url }}"
              alt="Sweatshirt vue de face">

            <!-- Vue de dos (cachée) -->
            <img class="product-img-single" id="view-dos"
              src="{{ 'sweatshirt-dos.png' | asset_url }}"
              alt="Sweatshirt vue de dos">

            <!-- Vue de côté (cachée) -->
            <img class="product-img-single" id="view-cote"
              src="{{ 'sweatshirt-cote.png' | asset_url }}"
              alt="Sweatshirt vue de côté">
            
            <!-- Couche des logos déplaçables (par-dessus le vêtement) -->
            <div class="logo-layer" id="logo-layer" data-view="face" data-side="l">
              <!-- ZONES GUIDES (pointillés rouges) : délimitent où poser l'asset.
                   Visibles tant que la zone est vide. left/top/width/height en %.
                   VUE FACE : uniquement le LOGO CŒUR (poitrine, côté cœur = droite
                   de l'image). VUE CÔTÉ : la manche. VUE DOS : le grand logo. -->
              <div class="logo-zone for-face" id="zone-f"  data-zone="f"  style="left:53.5%; top:28%; width:6%; height:14%;"></div>
              <!-- Poitrine DROITE du porteur = GAUCHE de l'image (vue de face).
                   Miroir de la zone cœur : left = 100 - left(f) - width. -->
              <div class="logo-zone for-face" id="zone-fr" data-zone="fr" style="left:40.5%; top:28%; width:6%; height:14%;"></div>
              <div class="logo-zone for-dos"  id="zone-b"  data-zone="b"  style="left:38%; top:23%; width:24%; height:46%;"></div>
              <!-- Manches : une zone par côté. L'image de profil est la même,
                   retournée en miroir pour la droite : la zone l'est aussi
                   (48% -> 46% = 100 - 48 - 6, la largeur de la zone). -->
              <div class="logo-zone for-cote side-l" id="zone-sl" data-zone="sl" style="left:48%; top:29%; width:6%; height:11%;"></div>
              <div class="logo-zone for-cote side-r" id="zone-sr" data-zone="sr" style="left:46%; top:29%; width:6%; height:11%;"></div>

              <!-- Textes déplaçables + redimensionnables (face / dos) -->
              <div class="design-text for-face" id="text-f" style="display:none; left:44%; top:31%; width:22%; font-size:20px; color:#ffffff;"><span class="dt-content"></span><span class="logo-resize" data-resize="text-f"></span></div>
              <div class="design-text for-face" id="text-fr" style="display:none; left:34%; top:31%; width:22%; font-size:20px; color:#ffffff;"><span class="dt-content"></span><span class="logo-resize" data-resize="text-fr"></span></div>
              <div class="design-text for-dos"  id="text-b" style="display:none; left:36%; top:27%; width:28%; font-size:26px; color:#ffffff;"><span class="dt-content"></span><span class="logo-resize" data-resize="text-b"></span></div>

              <!-- Logo cœur : visible sur la vue de face -->
              <div class="design-logo for-face" id="logo-f" data-zone="f" style="display:none; left:38%; top:34%; width:18%;">
                <img src="" alt="Logo cœur" draggable="false">
                <span class="logo-resize" data-resize="f"></span>
              </div>
              <!-- Logo poitrine droite (du porteur) : visible sur la vue de face -->
              <div class="design-logo for-face" id="logo-fr" data-zone="fr" style="display:none; left:44%; top:34%; width:18%;">
                <img src="" alt="Logo poitrine droite" draggable="false">
                <span class="logo-resize" data-resize="fr"></span>
              </div>
              <!-- Logo dos : visible sur la vue de dos -->
              <div class="design-logo for-dos" id="logo-b" data-zone="b" style="display:none; left:32%; top:30%; width:34%;">
                <img src="" alt="Logo dos" draggable="false">
                <span class="logo-resize" data-resize="b"></span>
              </div>
              <!-- Logos manches : visibles sur la vue de côté, un par côté.
                   side-l / side-r : n'apparaissent que sur le côté affiché. -->
              <div class="design-logo for-cote side-l" id="logo-sl" data-zone="sl" style="display:none; left:48%; top:31%; width:6%;">
                <img src="" alt="Logo manche gauche" draggable="false">
                <span class="logo-resize" data-resize="sl"></span>
              </div>
              <div class="design-logo for-cote side-r" id="logo-sr" data-zone="sr" style="display:none; left:46%; top:31%; width:6%;">
                <img src="" alt="Logo manche droite" draggable="false">
                <span class="logo-resize" data-resize="sr"></span>
              </div>
