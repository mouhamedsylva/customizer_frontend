    // Facteurs d'échelle visuelle par taille
    const SIZE_SCALES = { 'XS': 0.84, 'S': 0.92, 'M': 1.0, 'L': 1.08, 'XL': 1.16, 'XXL': 1.24 };

    function applyProductSize(size) {
      const scale = SIZE_SCALES[size] || 1.0;
      const view = document.querySelector('.cv-single-view');
      if (view) {
        view.dataset.sizeScale = scale; // ← mémoriser l'échelle taille
        const combined = (zl / 100) * scale;
        view.style.transform = `scale(${combined})`;
        view.style.transformOrigin = 'center center';
        view.style.transition = 'transform 0.25s ease';
      }
    }

