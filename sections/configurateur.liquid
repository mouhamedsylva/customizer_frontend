        // img.src vaut l'URL absolue de la page quand il est vide — on filtre ça
        const src = img ? img.getAttribute('src') : null;
        LOGO_STORE[productKey][zone] = (src && src !== '' && src.startsWith('data:')) ? src : null;
      });
