  <script>
    /* ── State ── */
    let zl = 100;
    let currentColor = '#1a1a1a';
    let currentColorName = 'Noir';
    let currentColorSlug = 'noir';
    let currentProductKey = 'sweatshirt';

    /* ── Couleurs : nom affiché -> slug de fichier ── */
    const COLOR_SLUGS = {
      'Noir': 'noir',
      'Blanc cassé': 'blanc-casse',
      'Gris': 'gris',
      'Gris foncé': 'gris-fonce',
      'Gris ardoise': 'gris-ardoise',
      'Bleu marine': 'bleu-marine',
      'Bleu ciel': 'bleu-ciel',
      'Vert foncé': 'vert-fonce',
      'Rose clair': 'rose-clair',
      'Rose': 'rose',
      'Rouge': 'rouge',
      'Orange': 'orange',
      'Jaune': 'jaune',
      'Violet': 'violet',
      'Marron': 'marron'
    };

    /* ── Produits : data-product -> préfixe de fichier ── */
    const PRODUCT_SLUGS = {
      'sweatshirt': 'sweatshirt',
      'tshirt': 'tshirt',
      'tshirt_polyester': 'tshirt-polyester'
    };

    /* Charge les images {produit}-{couleur}-{vue}.png pour les 3 vues.
       Repli automatique sur l'image générique si le fichier couleur manque. */
    function updateProductImages() {
      const prefix = PRODUCT_SLUGS[currentProductKey];
      if (!prefix) return; // produit non textile (coins, drapeaux...) : on ne touche pas

      const urls = window.PRODUCT_IMAGE_URLS || {};

      ['face', 'dos', 'cote'].forEach(view => {
        const imgEl = document.getElementById('view-' + view);
        if (!imgEl) return;

        const key = prefix + '-' + currentColorSlug + '-' + view;
        const colorUrl = urls[key];
        if (!colorUrl) return; // pas d'URL générée pour cette combinaison : on ne touche pas
        if (imgEl.src === colorUrl) return; // déjà la bonne image

        // Précharge la nouvelle image, puis la remplace INSTANTANÉMENT une fois prête.
        // Comme elle est déjà en cache, le changement est net et sans clignotement :
        // on a l'impression que seule la couleur change.
        imgEl.style.transition = 'none';
        const test = new Image();
        test.onload = () => { imgEl.src = colorUrl; };
        test.onerror = () => { /* image absente : on conserve l'image actuelle */ };
        test.src = colorUrl;
      });
    }

    /* ── Applique la couleur : charge les images correspondantes ── */
    function applyColor(hex) {
      updateProductImages();
    }

    function shadeHex(hex, pct) {
      const n = parseInt(hex.replace('#',''), 16);
      const r = Math.min(255, Math.max(0, (n>>16) + pct));
      const g = Math.min(255, Math.max(0, ((n>>8)&0xff) + pct));
      const b = Math.min(255, Math.max(0, (n&0xff) + pct));
      return '#' + [r,g,b].map(v=>v.toString(16).padStart(2,'0')).join('');
    }

    /* ── Product select ── */
    function selProd(el) {
      document.querySelectorAll('.pt').forEach(c => c.classList.remove('on'));
      el.classList.add('on');

      // Changer la layout et les images via le DynamicLayoutManager
      const productType = el.dataset.product;
      if (productType && window.dynamicLayoutManager) {
        window.dynamicLayoutManager.handleProductChange(productType);
      }

      // Pour les textiles : charger les images avec la couleur courante
      if (productType && (productType === 'sweatshirt' || productType === 'tshirt' || productType === 'tshirt_polyester')) {
        currentProductKey = productType;
        updateProductImages();
      }
    }

    /* ── Color select ── */
    function selColor(el, hex, name) {
      document.querySelectorAll('.cs').forEach(s => s.classList.remove('on'));
      el.classList.add('on');
      currentColor = hex;
      currentColorName = name;
      currentColorSlug = COLOR_SLUGS[name] || 'noir';
      applyColor(hex);
      document.getElementById('rc-color').textContent = 'Couleur : ' + name;
    }

    /* ── Size select ── */
    function selSize(el) {
      document.querySelectorAll('.sb').forEach(b => b.classList.remove('on'));
      el.classList.add('on');

      const size = el.textContent.trim();
      document.getElementById('rc-size').textContent = 'Taille : ' + size;

      // Répercute la taille sur le visuel du produit (échelle proportionnelle)
      applyProductSize(size);
    }

    // Facteurs d'échelle visuelle par taille
    const SIZE_SCALES = { 'XS': 0.84, 'S': 0.92, 'M': 1.0, 'L': 1.08, 'XL': 1.16, 'XXL': 1.24 };

    function applyProductSize(size) {
      const scale = SIZE_SCALES[size] || 1.0;
      const view = document.querySelector('.cv-single-view');
      if (view) {
        view.style.transform = `scale(${scale})`;
        view.style.transformOrigin = 'center center';
        view.style.transition = 'transform 0.25s ease';
      }
    }

    /* ── View tabs : gérées par conf-view-switcher.js (selView global) ── */

    /* ── Zoom ── */
    function zoom(d) {
      zl = Math.min(200, Math.max(50, zl + d));
      document.getElementById('zlvl').textContent = zl + '%';
      document.querySelectorAll('.cv-view, .coins-canvas-circle, .flag-stage, .coin-stage').forEach(v => {
        v.style.transform = `scale(${zl/100})`;
        v.style.transformOrigin = 'center center';
      });
    }
    function resetZoom() {
      zl = 100;
      document.getElementById('zlvl').textContent = '100%';
      document.querySelectorAll('.cv-view, .coins-canvas-circle, .flag-stage, .coin-stage').forEach(v => { v.style.transform = ''; });
    }

    /* ── File upload ── */
    function doUpload(e, zone) {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = ev => {
        const src = ev.target.result;

        // Si c'est un upload de coin
        if (zone === 'c') {
          // Preview dans la sidebar
          const prev = document.getElementById('pc');
          const img  = document.getElementById('ic');
          const lbl  = document.getElementById('lc');
          if (prev && img) { img.src = src; prev.style.display = 'block'; }
          if (lbl) lbl.style.display = 'flex';
          
          // Afficher dans le canvas circulaire
          const coinsCanvas = document.getElementById('coins-canvas');
          const coinsPreviewImg = document.getElementById('coins-preview-img');
          if (coinsCanvas && coinsPreviewImg) {
            coinsPreviewImg.src = src;
            coinsPreviewImg.style.display = 'block';
            coinsCanvas.classList.add('has-image');
          }
          
          // Recap - dans la miniature ronde
          const recapThumb = document.getElementById('coins-recap-thumb');
          if (recapThumb) {
            recapThumb.innerHTML = `<img src="${src}" alt="Patch" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`;
          }
          
          return;
        }

        // Si c'est un upload de coin métallique (recto / verso)
        if (zone === 'coin-recto' || zone === 'coin-verso') {
          const face = zone === 'coin-recto' ? 'recto' : 'verso';
          const disc = document.getElementById('coin-disc-' + face);
          if (disc) {
            const ph  = disc.querySelector('.coin-placeholder');
            const img = disc.querySelector('.coin-design-img');
            if (ph)  ph.style.display = 'none';
            if (img) { img.src = src; img.style.display = 'block'; }
          }
          // Miniatures du récap
          const thumbMain = document.getElementById('coin-recap-thumb-main');
          const thumbFace = document.getElementById('coin-recap-thumb-' + face);
          const imgHtml = `<img src="${src}" alt="${face}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`;
          if (thumbFace) thumbFace.innerHTML = imgHtml;
          if (face === 'recto' && thumbMain) thumbMain.innerHTML = imgHtml;
          return;
        }

        // Si c'est un upload de drapeau (recto / verso)
        if (zone === 'flag-recto' || zone === 'flag-verso') {
          const wrap = document.getElementById(zone);
          if (wrap) {
            // Mettre à jour les deux vues (3D image + 2D codé)
            wrap.querySelectorAll('.flag-canvas-placeholder').forEach(ph => ph.style.display = 'none');
            wrap.querySelectorAll('.flag-design-img').forEach(img => { img.src = src; img.style.display = 'block'; });
          }
          // Miniature du récap (recto uniquement)
          if (zone === 'flag-recto') {
            const recapThumb = document.getElementById('flag-recap-thumb');
            if (recapThumb) {
              recapThumb.innerHTML = `<img src="${src}" alt="Drapeau" style="width:100%;height:100%;object-fit:cover;border-radius:4px;">`;
            }
          }
          return;
        }

        // Sidebar preview (textiles)
        const prev = document.getElementById('p' + zone);
        const img  = document.getElementById('i' + zone);
        const lbl  = document.getElementById('l' + zone);
        if (prev && img) { img.src = src; prev.style.display = 'block'; }
        if (lbl)          lbl.style.display = 'flex';

        // SVG overlay
        const ov = document.getElementById('ov-' + zone);
        if (ov) { ov.setAttribute('href', src); ov.style.display = 'block'; }

        // Mirror sleeves to back view
        if (zone === 'sl') {
          const o2 = document.getElementById('ov-sl2');
          if (o2) { o2.setAttribute('href', src); o2.style.display = 'block'; }
          document.getElementById('rc-sleeves').style.display = 'flex';
        }
        if (zone === 'sr') {
          const o2 = document.getElementById('ov-sr2');
          if (o2) { o2.setAttribute('href', src); o2.style.display = 'block'; }
          document.getElementById('rc-sleeves').style.display = 'flex';
        }

        // Logo cœur déplaçable sur le produit (vue de face)
        if (zone === 'f') {
          const logo = document.getElementById('logo-f');
          if (logo) {
            const limg = logo.querySelector('img');
            if (limg) limg.src = src;
            logo.style.display = 'block';
          }
        }

        // Logo dos déplaçable sur le produit + bascule automatique vers la vue de dos
        if (zone === 'b') {
          const logo = document.getElementById('logo-b');
          if (logo) {
            const limg = logo.querySelector('img');
            if (limg) limg.src = src;
            logo.style.display = 'block';
          }
          // Basculer vers la vue de dos pour que le client positionne le logo
          const dosBtn = document.querySelector('.vt[onclick*="dos"]');
          if (dosBtn && typeof selView === 'function') {
            selView(dosBtn, 'dos');
          }
        }

        // Recap rows
        if (zone === 'f') {
          document.getElementById('rc-img-f').src = src;
          document.getElementById('rc-front').style.display = 'flex';
        }
        if (zone === 'b') {
          document.getElementById('rc-img-b').src = src;
          document.getElementById('rc-back').style.display = 'flex';
        }
      };
      reader.readAsDataURL(file);
    }

    function rmUp(zone) {
      // Si c'est un coin
      if (zone === 'c') {
        const prev = document.getElementById('pc');
        const img  = document.getElementById('ic');
        const lbl  = document.getElementById('lc');
        const input = document.getElementById('uc');
        
        if (img) img.src = '';
        if (prev) prev.style.display = 'none';
        if (lbl) lbl.style.display = 'none';
        if (input) input.value = '';
        
        // Cacher dans le canvas
        const coinsCanvas = document.getElementById('coins-canvas');
        const coinsPreviewImg = document.getElementById('coins-preview-img');
        if (coinsCanvas) coinsCanvas.classList.remove('has-image');
        if (coinsPreviewImg) {
          coinsPreviewImg.src = '';
          coinsPreviewImg.style.display = 'none';
        }
        
        // Cacher dans le récap
        const rcCoinLogo = document.getElementById('rc-coin-logo');
        if (rcCoinLogo) rcCoinLogo.style.display = 'none';
        
        return;
      }
      
      // Textiles
      ['p','i','l'].forEach(pfx => {
        const el = document.getElementById(pfx + zone);
        if (!el) return;
        if (pfx === 'i') el.src = '';
        else if (pfx === 'p') el.style.display = 'none';
        else el.style.display = 'none';
      });
      const input = document.getElementById('u' + zone);
      if (input) input.value = '';
      const ov = document.getElementById('ov-' + zone);
      if (ov) { ov.removeAttribute('href'); ov.style.display = 'none'; }
      if (zone === 'f') document.getElementById('rc-front').style.display = 'none';
      if (zone === 'b') document.getElementById('rc-back').style.display = 'none';
      if (zone === 'sl' || zone === 'sr') {
        const slSrc = document.getElementById('isl')?.src;
        const srSrc = document.getElementById('isr')?.src;
        if (!slSrc && !srSrc) document.getElementById('rc-sleeves').style.display = 'none';
      }
    }

    /* ── Coins functions ── */
    function selectShape(el) {
      document.querySelectorAll('.coins-shape-card').forEach(s => s.classList.remove('active'));
      el.classList.add('active');
      const shapeName = el.querySelector('span').textContent;
      console.log('Forme sélectionnée:', el.dataset.shape);
      
      // Mettre à jour le récap
      const recapShape = document.getElementById('coins-recap-shape');
      if (recapShape) recapShape.textContent = shapeName;
    }

    function selectCoinSize(el) {
      document.querySelectorAll('.coins-size-card').forEach(s => s.classList.remove('active'));
      el.classList.add('active');
      const sizeName = el.querySelector('p').textContent;
      console.log('Taille sélectionnée:', el.dataset.size);
      
      // Mettre à jour le récap
      const recapSize = document.getElementById('coins-recap-size');
      if (recapSize) recapSize.textContent = sizeName;
    }

    function selectFabrication(el) {
      document.querySelectorAll('.conf-fabrication-option').forEach(f => f.classList.remove('active'));
      el.classList.add('active');
      const radio = el.querySelector('input[type="radio"]');
      if (radio) radio.checked = true;
      const typeName = el.querySelector('strong').textContent;
      console.log('Fabrication sélectionnée:', el.dataset.fabrication);
      
      // Mettre à jour le récap
      const recapType = document.getElementById('coins-recap-type');
      if (recapType) recapType.textContent = typeName;
    }

    function switchCoinsView(view) {
      // Supprimer la classe 'on' de tous les onglets
      document.querySelectorAll('.vtabs .vt').forEach(t => t.classList.remove('on'));
      
      // Ajouter la classe 'on' à l'onglet cliqué
      event.target.classList.add('on');
      
      console.log('Vue coins:', view);
      
      // TODO: Implémenter vraiment les différentes vues (2D vs réel)
      // Pour l'instant, juste changer l'apparence de l'onglet
    }

    /* ── Quantity management for Coins ── */
    function changeQty(delta) {
      const input = document.getElementById('coin-qty-input');
      if (!input) return;
      
      let currentQty = parseInt(input.value) || 20;
      let newQty = currentQty + delta;
      
      // Minimum 20 unités
      if (newQty < 20) newQty = 20;
      
      input.value = newQty;
      updateCoinPrice(newQty);
    }

    function handleQtyInput() {
      const input = document.getElementById('coin-qty-input');
      if (!input) return;
      
      let qty = parseInt(input.value) || 20;
      
      // Minimum 20 unités
      if (qty < 20) {
        qty = 20;
        input.value = qty;
      }
      
      updateCoinPrice(qty);
    }

    function updateCoinPrice(qty) {
      const pricePerUnit = 2.45; // Prix unitaire HT
      const totalHT = pricePerUnit * qty;
      const totalTTC = totalHT * 1.20; // TVA 20%
      
      // Mettre à jour l'affichage de la quantité
      const qtyDisplay = document.getElementById('coins-qty-display');
      if (qtyDisplay) {
        qtyDisplay.textContent = `à partir de (${qty} unités)`;
      }
      
      // Mettre à jour le prix total HT
      const totalPrice = document.getElementById('coins-total-price');
      if (totalPrice) {
        totalPrice.textContent = totalHT.toFixed(2) + ' €';
      }
      
      // Mettre à jour le prix total TTC
      const totalTtc = document.getElementById('coins-total-ttc');
      if (totalTtc) {
        totalTtc.textContent = totalTTC.toFixed(2) + ' € TTC';
      }
      
      console.log('Quantité:', qty, '| Prix total HT:', totalHT.toFixed(2), '€ | TTC:', totalTTC.toFixed(2), '€');
    }

    /* ── Contact for custom (PVC/Tissé) ── */
    function contactForCustom() {
      // Ouvrir un modal ou rediriger vers la page de contact
      alert('Contactez-nous pour une commande PVC ou Tissé personnalisée !\n\nEmail: contact@customtextile.com\nTél: +33 1 23 45 67 89');
      // TODO: Implémenter un vrai formulaire de contact ou modal
    }

    /* ── Init : charge les images de la couleur par défaut au démarrage ── */
    document.addEventListener('DOMContentLoaded', () => {
      updateProductImages();
    });
  </script>
