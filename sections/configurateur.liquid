    <!-- Aperçu d'une ligne (couleur + design) -->
    <div class="grp-preview-overlay" id="grp-preview-overlay" onclick="if(event.target===this)closeGroupPreview()">
      <div class="grp-preview-box">
        <button class="grp-x" onclick="closeGroupPreview()" title="Fermer">✕</button>
        <div class="grp-preview-title" id="grp-preview-title">Aperçu</div>
        <div class="grp-preview-stage" id="grp-preview-stage"></div>
