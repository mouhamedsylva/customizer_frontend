        <!-- Manches row -->
        <div class="ri" id="rc-sleeves" style="display:none">
          <div class="ri-thumb">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="#888"><path d="M16 5v2h-3V3H11v4H8V5L3 8v3h2v9h14V11h2V8l-5-3z"/></svg>
          </div>
