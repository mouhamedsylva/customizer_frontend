  {% layout none %}
  <!DOCTYPE html>
  <html lang="fr">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configurateur Custom Textile</title>
    {{ 'configurateur.css' | asset_url | stylesheet_tag }}
    {{ 'conf-coins.css' | asset_url | stylesheet_tag }}
    {{ 'conf-drapeaux.css' | asset_url | stylesheet_tag }}
    {{ 'conf-patches.css' | asset_url | stylesheet_tag }}
    <script>
      // URL de base du backend NestJS (déployé sur Railway)
      window.API_BASE = "https://customizer-backend-production-6ed2.up.railway.app/api";

      window.ASSET_URLS = {
        visa: "{{ 'visa.svg' | asset_url }}",
        mastercard: "{{ 'mastercard.svg' | asset_url }}",
        applepay: "{{ 'applepay.svg' | asset_url }}",
        paypal: "{{ 'paypal.svg' | asset_url }}",
        patchRecto: "{{ 'patch-recto.png' | asset_url }}",
        patchVerso: "{{ 'patch-verso.png' | asset_url }}",
        patchCote: "{{ 'patch-cote.png' | asset_url }}",
        flagRecto: "{{ 'flag-recto.png' | asset_url }}",
        flagVerso: "{{ 'flag-verso.png' | asset_url }}",
        flag4anRecto: "{{ 'flag-4an-recto.png' | asset_url }}",
        flag4anVerso: "{{ 'flag-4an-verso.png' | asset_url }}",
        // Versions PORTRAIT (drapeau vertical)
        flagRectoPortrait: "{{ 'flag-recto-portrait.png' | asset_url }}",
        flagVersoPortrait: "{{ 'flag-verso-portrait.png' | asset_url }}",
        flag4anRectoPortrait: "{{ 'flag-4an-recto-portrait.png' | asset_url }}",
        flag4anVersoPortrait: "{{ 'flag-4an-verso-portrait.png' | asset_url }}"
      };

      // Dictionnaire de toutes les images textile (clé = "produit-couleur-vue")
      // Généré côté Liquid pour avoir les URLs CDN exactes (avec ?v=...).
      window.PRODUCT_IMAGE_URLS = {
        {%- assign tx_products = "sweatshirt,tshirt,tshirt-polyester" | split: "," -%}
        {%- assign tx_colors = "noir,blanc-casse,gris,gris-fonce,gris-ardoise,bleu-marine,bleu-ciel,vert-fonce,rose-clair,rose,rouge,orange,jaune,violet,marron" | split: "," -%}
        {%- assign tx_views = "face,dos,cote" | split: "," -%}
        {%- for p in tx_products -%}
          {%- for c in tx_colors -%}
            {%- for v in tx_views -%}
              {%- assign fname = p | append: "-" | append: c | append: "-" | append: v | append: ".png" -%}
              "{{ p }}-{{ c }}-{{ v }}": "{{ fname | asset_url }}",
            {%- endfor -%}
          {%- endfor -%}
        {%- endfor -%}
      };

      window.COIN_IMAGE_URLS = {
        'patch-recto-or':     "{{ 'patch-recto-or.png'     | asset_url }}",
        'patch-recto-argent': "{{ 'patch-recto-argent.png' | asset_url }}",
        'patch-recto-nickel': "{{ 'patch-recto-nickel.png' | asset_url }}",
        'patch-recto-bronze': "{{ 'patch-recto-bronze.png' | asset_url }}",
        'patch-recto-cuivre': "{{ 'patch-recto-cuivre.png' | asset_url }}",

        'patch-verso-or':     "{{ 'patch-verso-or.png'     | asset_url }}",
        'patch-verso-argent': "{{ 'patch-verso-argent.png' | asset_url }}",
        'patch-verso-nickel': "{{ 'patch-verso-nickel.png' | asset_url }}",
        'patch-verso-bronze': "{{ 'patch-verso-bronze.png' | asset_url }}",
        'patch-verso-cuivre': "{{ 'patch-verso-cuivre.png' | asset_url }}",

        'patch-cote-or':     "{{ 'patch-cote-or.png'     | asset_url }}",
        'patch-cote-argent': "{{ 'patch-cote-argent.png' | asset_url }}",
        'patch-cote-nickel': "{{ 'patch-cote-nickel.png' | asset_url }}",
        'patch-cote-bronze': "{{ 'patch-cote-bronze.png' | asset_url }}",
        'patch-cote-cuivre': "{{ 'patch-cote-cuivre.png' | asset_url }}"
      };

      // Images génériques (sans couleur) servant de repli si une image couleur manque
      window.PRODUCT_FALLBACK_URLS = {
        "sweatshirt": {
          face: "{{ 'sweatshirt-face.png' | asset_url }}",
          dos:  "{{ 'sweatshirt-dos.png' | asset_url }}",
          cote: "{{ 'sweatshirt-t-cote.png' | asset_url }}"
        },
        "tshirt": {
          face: "{{ 'tshirt-face.png' | asset_url }}",
          dos:  "{{ 'tshirt-dos.png' | asset_url }}",
          cote: "{{ 'tshirt-cote.png' | asset_url }}"
        },
        "tshirt-polyester": {
          face: "{{ 'tshirt-polyester-face.png' | asset_url }}",
          dos:  "{{ 'tshirt-polyester-dos.png' | asset_url }}",
          cote: "{{ 'tshirt-polyester-cote.png' | asset_url }}"
        }
      };
    </script>
    <script src="{{ 'conf-alert.js' | asset_url }}"></script>
    <script src="{{ 'conf-product-images.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-dynamic-layout.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-drapeaux.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-patches.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-logo-drag.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-api.js' | asset_url }}" defer></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #1a1a1a;
      --white: #ffffff;
      --border: #e5e5e5;
      --bg-light: #f8f8f8;
      --muted: #666;
      --faint: #999;
      --blue: #2c5aa0;
      --r: 7px;
      --header-h: 58px;
      --typebar-h: 132px;
      --sidebar-w: 320px;
      --recap-w: 252px;
    }

    .conf-app-root {
      height: 100vh;
      overflow: hidden;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      color: var(--black);
      background: var(--white);
      font-size: 12px;
      display: grid;
      grid-template-columns: 1fr var(--recap-w);
      grid-template-rows: var(--header-h) var(--typebar-h) 1fr;
      grid-template-areas:
        "header  header"
        "typebar recap"
        "main    recap";
    }

    /* ══ HEADER ══ */
    .hdr {
      display: flex;
      align-items: center;
      height: var(--header-h);
      padding: 0 20px;
      border-bottom: 1px solid var(--border);
      background: var(--white);
      flex-shrink: 0;
      gap: 12px;
      position: relative;
      z-index: 10;
      grid-area: header;
      border-right: 1px solid var(--border);
    }
    .hdr-brand {
      display: flex; align-items: center; gap: 10px;
      min-width: 190px;
    }
    .hdr-icon {
      width: 34px; height: 34px;
      background: var(--black); border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: 17px; flex-shrink: 0;
    }
    .hdr-name { font-size: 13px; font-weight: 700; letter-spacing: .4px; line-height: 1.1; }
    .hdr-sub  { font-size: 10px; color: var(--muted); }
    .hdr-steps {
      flex: 1;
      display: flex; align-items: center; justify-content: center; gap: 6px;
    }
    .step { display: flex; align-items: center; gap: 6px; color: var(--muted); font-size: 12px; }
    .step-n {
      width: 26px; height: 26px; border-radius: 50%;
      border: 2px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 700; background: var(--white);
    }
    .step.on .step-n { background: var(--black); border-color: var(--black); color: #fff; }
    .step.on .step-lbl { color: var(--black); font-weight: 600; }
    .step-line { width: 36px; height: 1px; background: var(--border); }
    .hdr-btns { display: flex; gap: 8px; min-width: 190px; justify-content: flex-end; }
    .obtn {
      display: flex; align-items: center; gap: 5px;
      padding: 6px 13px;
      border: 1px solid var(--border); border-radius: 6px;
      background: var(--white); font-size: 12px; font-weight: 500;
      cursor: pointer; color: var(--black); transition: border-color .15s;
    }
    .obtn:hover { border-color: var(--black); }

    /* ══ BODY ══ */
    .app {
      display: flex;
      height: 100%;
      overflow: hidden;
      grid-area: main;
    }

    /* ══ SIDEBAR ══ */
    .sidebar {
      width: var(--sidebar-w);
      border-right: 1px solid var(--border);
      display: flex; flex-direction: column;
      overflow: hidden;
      flex-shrink: 0;
    }
    /* inner scroll only if needed but designed to NOT need it */
    .sb-inner {
      flex: 1;
      overflow-y: auto;
      overflow-x: hidden;
    }
    .sb-inner::-webkit-scrollbar { width: 3px; }
    .sb-inner::-webkit-scrollbar-thumb { background: #ddd; border-radius: 2px; }

    .sec {
      padding: 8px 14px;
      border-bottom: 1px solid var(--border);
    }
    .sec-title {
      font-size: 10px; font-weight: 700;
      text-transform: uppercase; letter-spacing: .5px;
      margin-bottom: 2px; color: var(--black);
    }
    .sec-sub {
      font-size: 10px; color: var(--faint); margin-bottom: 8px;
    }

    /* Product type grid */
    .pg {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 6px;
    }
    .pc {
      display: flex; flex-direction: column; align-items: center;
      padding: 8px 4px 7px;
      border: 2px solid var(--border); border-radius: 6px;
      cursor: pointer; transition: all .15s;
      font-size: 9px; font-weight: 600; color: var(--black);
      text-align: center; line-height: 1.2; gap: 4px;
      position: relative; background: var(--white);
    }
    .pc:hover { border-color: #999; }
    .pc.on { background: var(--black); border-color: var(--black); color: #fff; }
    .pc.on .pc-ico { background: rgba(255,255,255,.15); }
    .pc-ico {
      width: 32px; height: 32px; border-radius: 50%;
      background: var(--bg-light);
      display: flex; align-items: center; justify-content: center;
    }
    .pc-ico svg { width: 18px; height: 18px; }
    .ck {
      position: absolute; top: 3px; right: 3px;
      width: 14px; height: 14px; background: var(--white);
      border-radius: 50%; display: none; align-items: center;
      justify-content: center; font-size: 8px; color: var(--black); font-weight: 900;
    }
    .pc.on .ck { display: flex; }

    /* Color grid */
    .cg {
      display: flex;
      flex-wrap: wrap;
      row-gap: 4px;
    }
    .cg-row {
      display: flex;
      width: 100%;
      justify-content: space-between;
    }
    .cs {
      width: 18px; height: 18px; border-radius: 4px;
      cursor: pointer; border: 2px solid transparent;
      transition: transform .13s;
      position: relative;
      flex-shrink: 0;
    }
    .cs:hover { transform: scale(1.12); }
    .cs.on { box-shadow: 0 0 0 2px #fff, 0 0 0 4px var(--black); }
    .cs.on::after {
      content: '✓'; position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: 9px; font-weight: 700;
      text-shadow: 0 1px 3px rgba(0,0,0,.6);
    }

    /* Size */
    .sg { display: flex; gap: 4px; flex-wrap: nowrap; align-items: center; }
    .sb {
      padding: 3px 8px;
      border: 1.5px solid var(--border); border-radius: 4px;
      font-size: 10px; font-weight: 600; cursor: pointer;
      background: var(--white); color: var(--black); transition: all .13s;
      min-width: 26px; text-align: center;
    }
    .sb:hover { border-color: var(--black); }
    .sb.on { background: var(--black); border-color: var(--black); color: #fff; }
    .sgd { display: inline-flex; align-items: center; gap: 3px; font-size: 10px; color: var(--muted); margin-top: 5px; cursor: pointer; text-decoration: underline; }

    /* Upload */
    .uz {
      border: 2px dashed var(--border); border-radius: 6px;
      padding: 7px 8px; text-align: center; cursor: pointer;
      background: #fafafa; transition: all .15s;
      display: flex; align-items: center; gap: 8px;
      justify-content: center;
    }
    .uz:hover { border-color: #999; background: #f3f3f3; }
    .uz-ico {
      width: 22px; height: 22px; background: #eee; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .uz p { font-size: 9px; color: var(--muted); line-height: 1.3; text-align: left; }
    .uz strong { color: var(--muted); }

    .uprev {
      display: none; margin-top: 4px;
      border: 1px solid var(--border); border-radius: 5px;
      padding: 4px 6px; position: relative;
      /* Fond en damier : rend visibles les logos blancs / transparents */
      background-color: #e8e8e8;
      background-image:
        linear-gradient(45deg, #c9c9c9 25%, transparent 25%),
        linear-gradient(-45deg, #c9c9c9 25%, transparent 25%),
        linear-gradient(45deg, transparent 75%, #c9c9c9 75%),
        linear-gradient(-45deg, transparent 75%, #c9c9c9 75%);
      background-size: 10px 10px;
      background-position: 0 0, 0 5px, 5px -5px, -5px 0;
    }
    .uprev img { width: 100%; height: 32px; object-fit: contain; display: block; }
    .uprev-lbl {
      display: none; align-items: center; justify-content: space-between;
      margin-top: 2px; font-size: 9px; color: var(--muted);
    }
    .rmv { color: #e33; font-size: 10px; cursor: pointer; border: none; background: none; font-family: inherit; display: flex; align-items: center; gap: 2px; }

    /* Sleeve grid */
    .slvg { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
    .slvg label { font-size: 9px; font-weight: 600; color: var(--muted); display: block; margin-bottom: 3px; }

    /* Info note */
    .note {
      display: flex; gap: 6px; background: #f5f5f5;
      border-radius: 5px; padding: 7px 8px;
      margin-top: 6px; font-size: 10px; color: var(--muted); line-height: 1.4;
      align-items: flex-start;
    }
    .note svg { flex-shrink: 0; margin-top: 1px; }

    /* ══ CANVAS ══ */
    .canvas {
      flex: 1;
      display: flex; flex-direction: column;
      background: var(--white);
      padding: 16px 20px 0;
      overflow: hidden;
      min-width: 0;
    }
    .cv-hdr { margin-bottom: 8px; flex-shrink: 0; }
    .cv-title { font-size: 13px; font-weight: 700; margin-bottom: 2px; }
    .cv-sub { font-size: 11px; color: var(--muted); margin-bottom: 10px; }
    .vtabs { display: flex; gap: 6px; }
    .vt {
      padding: 6px 14px; border: 1px solid var(--border);
      border-radius: 5px; background: #fff; font-size: 12px;
      font-weight: 500; cursor: pointer; color: var(--black); transition: all .13s;
    }
    .vt.on { background: var(--black); border-color: var(--black); color: #fff; }

    .cv-wrap {
      flex: 1;
      background: var(--white);
      border-radius: 0;
      box-shadow: none;
      position: relative;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
      min-height: 0;
    }

    .cv-view {
      display: none;
      align-items: center; justify-content: center;
      gap: 16px; height: 100%; width: 100%;
      padding: 16px 32px 60px;
    }
    .cv-view.on { display: flex; }

    .pslot {
      flex: 1; max-width: 260px;
      display: flex; align-items: center; justify-content: center;
      position: relative;
    }
    .pslot img.product-img {
      max-width: 100%; max-height: 280px;
      object-fit: contain; display: block;
      transition: filter .3s;
    }
    .pslot svg.product-svg {
      max-width: 100%; max-height: 280px;
    }

    /* measurement label */
    .mlbl {
      position: absolute; left: -36px; top: 35%;
      display: flex; align-items: center; gap: 4px;
      font-size: 10px; font-weight: 700;
    }
    .mline {
      width: 1px; height: 50px; background: var(--black);
      position: relative;
    }
    .mline::before, .mline::after {
      content: ''; position: absolute; left: -3px;
      width: 7px; height: 1px; background: var(--black);
    }
    .mline::before { top: 0; }
    .mline::after { bottom: 0; }
    .mlbl-r { left: auto; right: -36px; }

    /* Canvas row : image + zoom côte à côte */
    .cv-canvas-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      flex: 1;
      min-height: 0;
      width: 100%;
    }

    /* Controls zoom – colonne verticale à droite de l'image */
    .cv-ctrl {
      display: flex; flex-direction: column; align-items: center; gap: 6px;
      background: rgba(255,255,255,.95);
      border: 1px solid var(--border); border-radius: 40px;
      padding: 10px 8px; box-shadow: 0 2px 10px rgba(0,0,0,.08);
      backdrop-filter: blur(8px);
      flex-shrink: 0;
    }
    .cbtn {
      width: 28px; height: 28px; border: none; background: none;
      cursor: pointer; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      transition: background .13s; color: var(--black);
    }
    .cbtn:hover { background: var(--bg-light); }
    .zlvl { font-size: 12px; font-weight: 600; min-width: 40px; text-align: center; }
    .cdiv { width: 18px; height: 1px; background: var(--border); }

    /* Info bar */
    .cv-info {
      position: absolute; bottom: 8px; left: 50%; transform: translateX(-50%);
      display: flex; align-items: center; gap: 5px;
      background: transparent; border: none;
      padding: 0;
      font-size: 10px; color: var(--faint);
      white-space: nowrap;
    }

    /* ══ RECAP ══ */
    .recap {
      width: var(--recap-w);
      border-left: 1px solid var(--border);
      display: flex; flex-direction: column;
      overflow-y: auto; overflow-x: hidden; flex-shrink: 0;
      grid-area: recap;
    }
    .recap::-webkit-scrollbar { width: 3px; }
    .recap::-webkit-scrollbar-thumb { background: #ddd; }
    .rp-hdr {
      padding: 12px 16px 10px;
      font-size: 10px; font-weight: 700;
      text-transform: uppercase; letter-spacing: .6px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .rp-items { flex: 1; overflow-y: auto; }
    .rp-items::-webkit-scrollbar { width: 3px; }
    .rp-items::-webkit-scrollbar-thumb { background: #ddd; }

    .ri {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 16px; border-bottom: 1px solid var(--border);
    }
    .ri-thumb {
      width: 40px; height: 40px; border-radius: 5px;
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; overflow: hidden;
      /* Fond en damier : rend visibles les logos blancs / transparents */
      background-color: #e8e8e8;
      background-image:
        linear-gradient(45deg, #c9c9c9 25%, transparent 25%),
        linear-gradient(-45deg, #c9c9c9 25%, transparent 25%),
        linear-gradient(45deg, transparent 75%, #c9c9c9 75%),
        linear-gradient(-45deg, transparent 75%, #c9c9c9 75%);
      background-size: 10px 10px;
      background-position: 0 0, 0 5px, 5px -5px, -5px 0;
    }
    .ri-thumb img { width: 100%; height: 100%; object-fit: contain; }
    .ri-info { flex: 1; min-width: 0; }
    .ri-name { font-size: 11px; font-weight: 600; margin-bottom: 2px; }
    .ri-det  { font-size: 10px; color: var(--muted); }
    .ri-ok   { font-size: 10px; color: #16a34a; font-weight: 600; }

    .rp-price {
      padding: 14px 16px 16px; border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .rp-plbl { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 4px; }
    .rp-pval { font-size: 20px; font-weight: 800; letter-spacing: -.3px; }
    .rp-pvat { font-size: 11px; color: var(--muted); font-weight: 400; }

    .rp-acts {
      padding: 12px 16px;
      display: flex; flex-direction: column; gap: 8px; flex-shrink: 0;
    }
    .btn-cart {
      width: 100%; padding: 11px;
      background: var(--black); color: #fff;
      border: none; border-radius: 6px;
      font-size: 12px; font-weight: 700;
      cursor: pointer; letter-spacing: .3px;
      display: flex; align-items: center; justify-content: center; gap: 6px;
      transition: background .2s;
    }
    .btn-cart:hover { background: #333; }
    .btn-save {
      width: 100%; padding: 9px;
      background: #fff; color: var(--black);
      border: 1.5px solid var(--border); border-radius: 6px;
      font-size: 11px; font-weight: 600; cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 6px;
      transition: border-color .15s;
    }
    .btn-save:hover { border-color: var(--black); }

    .rp-trust {
      padding: 10px 16px 24px;
      display: flex; flex-direction: column; gap: 8px;
      border-top: 1px solid var(--border); margin-top: auto;
    }
    .ti { display: flex; align-items: center; gap: 8px; }
    .ti-ico {
      width: 28px; height: 28px; background: var(--bg-light);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .ti-txt { font-size: 11px; font-weight: 600; line-height: 1; }
    .ti-txt span { display: block; font-size: 10px; color: var(--muted); font-weight: 400; margin-top: 2px; }

    /* ══ SHOPIFY COMPAT: Reset thème parent ══ */
    .conf-app-root *,
    .conf-app-root *::before,
    .conf-app-root *::after {
      box-sizing: border-box;
    }
    /* Annule le padding/margin du main Shopify si présent */
    .conf-app-root {
      position: fixed;
      inset: 0;
      z-index: 9999;
    }
    /* Sidebar scroll invisible mais fonctionnel */
    .sb-inner { scrollbar-width: thin; scrollbar-color: #ddd transparent; }
    /* Canvas occupe tout l'espace disponible */
    .cv-wrap { flex: 1 1 0; min-height: 0; }
    /* Recap: pas de scroll horizontal */
    .recap { overflow-x: hidden; }
    /* Assure que les hoodies SVG s'adaptent */
    .product-svg { width: 100%; height: auto; }


    /* ══ TYPE BAR ══ */
    .type-bar {
      height: var(--typebar-h);
      border-bottom: 1px solid var(--border);
      background: var(--white);
      display: flex;
      align-items: center;
      padding: 16px 20px 22px;
      flex-shrink: 0;
      grid-area: typebar;
      border-right: 1px solid var(--border);
    }
    .type-bar-inner {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      width: 100%;
    }
    .type-bar-label {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }
    .type-bar-num {
      font-size: 13px;
      font-weight: 800;
      color: var(--black);
    }
    .type-bar-title {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .5px;
      line-height: 1.2;
    }
    .type-bar-sub {
      font-size: 10px;
      color: var(--faint);
      margin-top: 1px;
    }
    .type-bar-cards {
      display: flex;
      gap: 8px;
      flex-wrap: nowrap;
      overflow-x: auto;
      width: 100%;
    }
    .type-bar-cards::-webkit-scrollbar { display: none; }

    /* Product type card — vertical layout with image */
    .pt {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 10px;
      padding: 8px 16px 8px 8px;
      border: 2px solid var(--border);
      border-radius: 8px;
      cursor: pointer;
      transition: all .15s;
      font-size: 12px;
      font-weight: 600;
      color: var(--black);
      background: var(--white);
      white-space: nowrap;
      position: relative;
      flex-shrink: 0;
      min-width: 132px;
    }
    .pt:hover { border-color: #999; background: var(--bg-light); }
    .pt.on {
      background: var(--white);
      border-color: var(--black);
      color: var(--black);
    }
    .pt-ico {
      width: 46px; height: 46px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .pt-img {
      width: 38px; height: 38px;
      object-fit: contain;
      display: block;
    }
    .pt-ck {
      position: absolute; top: -7px; right: -7px;
      width: 16px; height: 16px;
      border-radius: 50%;
      background: var(--black);
      color: var(--white);
      font-size: 9px; font-weight: 900;
      display: none;
      align-items: center; justify-content: center;
    }
    .pt.on .pt-ck { display: flex; }

    @keyframes cartBounce {
      0%   { transform: scale(1); }
      40%  { transform: scale(1.25); }
      70%  { transform: scale(0.9); }
      100% { transform: scale(1); }
    }

    .obtn-cart {
      position: relative;
      border-color: #1a1a1a;
      font-weight: 600;
    }
    .obtn-cart:hover {
      background: #f0f0f0;
    }


    /* ══ CART DRAWER ══ */
  .cart-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.45);
    z-index: 99998;
  }
  .cart-overlay.open { display: block; }

  .cart-drawer {
    position: fixed;
    top: 0; right: -420px;
    width: 100%; max-width: 400px;
    height: 100%;
    background: #fff;
    z-index: 99999;
    display: flex; flex-direction: column;
    box-shadow: -4px 0 24px rgba(0,0,0,.15);
    transition: right .3s cubic-bezier(.4,0,.2,1);
  }
  .cart-drawer.open { right: 0; }

  .cd-hdr {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 20px 16px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .cd-title { font-size: 16px; font-weight: 700; }
  .cd-count { font-size: 13px; color: var(--muted); font-weight: 400; margin-left: 6px; }
  .cd-close {
    width: 32px; height: 32px; border: none; background: none;
    cursor: pointer; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; color: var(--muted); transition: background .13s;
  }
  .cd-close:hover { background: var(--bg-light); color: var(--black); }

  .cd-items { flex: 1; overflow-y: auto; padding: 8px 0; }
  .cd-items::-webkit-scrollbar { width: 3px; }
  .cd-items::-webkit-scrollbar-thumb { background: #ddd; border-radius: 2px; }

  .cd-item {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
  }
  .cd-thumb {
    width: 72px; height: 72px; border-radius: 8px;
    background: var(--bg-light); border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; overflow: hidden;
  }
  .cd-thumb img { width: 100%; height: 100%; object-fit: contain; }
  .cd-info { flex: 1; min-width: 0; }
  .cd-name { font-size: 13px; font-weight: 700; margin-bottom: 4px; }
  .cd-meta { font-size: 11px; color: var(--muted); line-height: 1.6; }
  .cd-price { font-size: 14px; font-weight: 700; margin-top: 8px; }

  .cd-qty {
    display: flex; align-items: center; gap: 8px;
    margin-top: 10px;
  }
  .cd-qty-btn {
    width: 28px; height: 28px; border-radius: 50%;
    border: 1.5px solid var(--border); background: #fff;
    font-size: 16px; font-weight: 400; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: border-color .13s;
  }
  .cd-qty-btn:hover { border-color: var(--black); }
  .cd-qty-val { font-size: 13px; font-weight: 600; min-width: 20px; text-align: center; }
  .cd-delete {
    width: 28px; height: 28px; border: none; background: none;
    cursor: pointer; color: #aaa; display: flex; align-items: center;
    justify-content: center; border-radius: 50%; transition: color .13s, background .13s;
    margin-left: auto; align-self: flex-start;
  }
  .cd-delete:hover { color: #e33; background: #fee2e2; }

  .cd-empty {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; height: 100%; gap: 12px;
    color: var(--muted); font-size: 13px; text-align: center; padding: 40px;
  }

  .cd-footer {
    border-top: 1px solid var(--border);
    padding: 16px 20px 20px;
    flex-shrink: 0;
    background: #fff;
  }
  .cd-subtotal {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 4px;
  }
  .cd-subtotal-lbl { font-size: 12px; color: var(--muted); }
  .cd-subtotal-val { font-size: 18px; font-weight: 800; }
  .cd-tax-note { font-size: 10px; color: var(--faint); margin-bottom: 14px; }
  .cd-checkout {
    width: 100%; padding: 14px;
    background: var(--black); color: #fff;
    border: none; border-radius: 8px;
    font-size: 14px; font-weight: 700; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    transition: background .2s;
  }
  .cd-checkout:hover { background: #333; }
  .cd-continue {
    width: 100%; padding: 10px;
    background: #fff; color: var(--black);
    border: 1.5px solid var(--border); border-radius: 8px;
    font-size: 12px; font-weight: 600; cursor: pointer;
    margin-top: 8px; transition: border-color .15s;
  }
  .cd-continue:hover { border-color: var(--black); }


  </style>
