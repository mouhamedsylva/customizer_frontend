  {% layout none %}
  <!DOCTYPE html>
  <html lang="fr">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configurateur Custom Textile</title>
    {{ 'configurateur.css' | asset_url | stylesheet_tag }}
    {{ 'conf-coins.css' | asset_url | stylesheet_tag }}
    {{ 'conf-drapeaux.css' | asset_url | stylesheet_tag }}
    {{ 'conf-patches.css' | asset_url | stylesheet_tag }}
    <script>
      /* URL de base du backend NestJS (déployé sur Railway).
         Pilotée par le réglage de thème « API Endpoint » (settings.api_endpoint),
         modifiable dans Personnaliser > Paramètres du thème sans toucher au code.
         La valeur en dur ne sert que de repli si le réglage est vide ou resté sur
         le localhost par défaut — une URL codée en dur ici avait déjà provoqué
         l'envoi des devis vers une ancienne instance pendant plusieurs jours. */
      {%- assign api_setting = settings.api_endpoint | default: '' -%}
      {%- if api_setting == '' or api_setting contains 'localhost' -%}
        window.API_BASE = "https://customizer-backend-production-4c83.up.railway.app/api";
      {%- else -%}
        window.API_BASE = {{ api_setting | json }};
      {%- endif -%}

      /* ── PRIX UNITAIRES (définis par l'admin) ──────────────────────────────
         Source de vérité : GET /api/pricing (dashboard admin -> BDD).
         Les valeurs ci-dessous ne sont qu'un REPLI, utilisé si le backend est
         injoignable : l'affichage reste correct au lieu de tomber à 0.
         window.PRICES est renseigné dès la réponse, puis prixUnitaire() l'utilise. */
      window.PRICES = {
        sweatshirt: 45, tshirt: 25, tshirt_polyester: 28,
        coins: 2.45, drapeaux: 19.90, patches: 2.45
      };

      /** Prix unitaire HT d'un produit (clé de window.PRICES). */
      window.prixUnitaire = function (key) {
        var p = window.PRICES || {};
        var v = Number(p[key]);
        return isNaN(v) ? 0 : v;
      };

      /** Formate un prix à la française : 2.45 -> "2,45 €". */
      window.formatPrix = function (n) {
        return Number(n || 0).toFixed(2).replace('.', ',') + ' €';
      };

      /* Charge les prix réels au plus tôt. Quand ils arrivent, on notifie
         l'interface (les écrans déjà rendus se remettent à jour). */
      window.PRICES_READY = fetch(window.API_BASE + '/pricing')
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (d) {
          if (d && d.ok && d.prices) {
            window.PRICES = Object.assign({}, window.PRICES, d.prices);
            document.dispatchEvent(new CustomEvent('conf:prices-loaded'));
          }
          return window.PRICES;
        })
        .catch(function () { return window.PRICES; });   // repli silencieux

      /* Les prix arrivent APRÈS le premier rendu : on rafraîchit ce qui est
         déjà affiché (prix unitaires + total selon la quantité courante). */
      document.addEventListener('conf:prices-loaded', function () {
        var unit = document.getElementById('coins-unit-price');
        if (unit) {
          unit.innerHTML = window.formatPrix(window.prixUnitaire('patches')) +
                           ' <span class="rp-unit-ht">HT</span>';
        }
        var flags = document.getElementById('flags-unit-price');
        if (flags) {
          flags.innerHTML = window.formatPrix(window.prixUnitaire('drapeaux')) +
                            ' <span class="rp-unit-ht">HT</span>';
        }
        // Recalcule le total avec la quantité affichée.
        var qtyEl = document.getElementById('coin-qty-input') ||
                    document.getElementById('coin-recap-qty-input');
        if (qtyEl && typeof updateCoinPrice === 'function') {
          updateCoinPrice(parseInt(qtyEl.value, 10) || 20);
        }
      });

      window.ASSET_URLS = {
        visa: "{{ 'visa.svg' | asset_url }}",
        mastercard: "{{ 'mastercard.svg' | asset_url }}",
        applepay: "{{ 'applepay.svg' | asset_url }}",
        paypal: "{{ 'paypal.svg' | asset_url }}",
        patchRecto: "{{ 'patch-recto.png' | asset_url }}",
        patchVerso: "{{ 'patch-verso.png' | asset_url }}",
        patchCote: "{{ 'patch-cote.png' | asset_url }}",
        flagRecto: "{{ 'flag-recto.png' | asset_url }}",
        flagVerso: "{{ 'flag-verso.png' | asset_url }}",
        flag4anRecto: "{{ 'flag-4an-recto.png' | asset_url }}",
        flag4anVerso: "{{ 'flag-4an-verso.png' | asset_url }}",
        // Versions PORTRAIT (drapeau vertical)
        flagRectoPortrait: "{{ 'flag-recto-portrait.png' | asset_url }}",
        flagVersoPortrait: "{{ 'flag-verso-portrait.png' | asset_url }}",
        flag4anRectoPortrait: "{{ 'flag-4an-recto-portrait.png' | asset_url }}",
        flag4anVersoPortrait: "{{ 'flag-4an-verso-portrait.png' | asset_url }}"
      };

      /* Dictionnaire des images DRAPEAU, une par combinaison.
         Clé   : "{anneaux}-{couleur}-{face}-{orientation}"
         Ex.   : "2an-rouge-recto-paysage"
         Fichier attendu : flag-2an-rouge-recto-paysage.png
         16 couleurs × 2 anneaux × 2 faces × 2 orientations = 128 images. */
      window.FLAG_IMAGE_URLS = {
        {%- assign fl_anneaux = "2an,4an" | split: "," -%}
        {%- assign fl_colors = "blanc,noir,blanc-casse,gris,gris-fonce,gris-ardoise,bleu-marine,bleu-ciel,vert-fonce,rose-clair,rose,rouge,orange,jaune,violet,marron" | split: "," -%}
        {%- assign fl_faces = "recto,verso" | split: "," -%}
        {%- assign fl_orients = "paysage,portrait" | split: "," -%}
        {%- for a in fl_anneaux -%}
          {%- for c in fl_colors -%}
            {%- for f in fl_faces -%}
              {%- for o in fl_orients -%}
                {%- assign fname = "flag-" | append: a | append: "-" | append: c | append: "-" | append: f | append: "-" | append: o | append: ".png" -%}
                "{{ a }}-{{ c }}-{{ f }}-{{ o }}": "{{ fname | asset_url }}",
              {%- endfor -%}
            {%- endfor -%}
          {%- endfor -%}
        {%- endfor -%}
      };

      /* Dictionnaire des images PATCH, une par (forme × couleur).
         Clé   : "{forme}-{slug}"          Ex. : "rond-rouge"
         Fichier attendu : patch-{forme}-{slug}.png
         4 formes × 16 couleurs = 64 images. asset_url renvoie TOUJOURS une URL
         (même si le fichier n'existe pas encore) : le repli réel se fait côté JS
         par onload/onerror (comme loadFirstAvailable), avec repli sur l'image
         BLANCHE patch-{forme}-blanc.png teintée en CSS. */
      window.PATCH_IMAGE_URLS = {
        {%- assign pt_shapes = "rond,carre,rectangle,blason" | split: "," -%}
        {%- assign pt_colors = "noir,blanc-casse,gris,gris-fonce,gris-ardoise,bleu-marine,bleu-ciel,vert-fonce,rose-clair,rose,rouge,orange,jaune,violet,marron,blanc" | split: "," -%}
        {%- for s in pt_shapes -%}
          {%- for c in pt_colors -%}
            {%- assign pname = "patch-" | append: s | append: "-" | append: c | append: ".png" -%}
            "{{ s }}-{{ c }}": "{{ pname | asset_url }}",
          {%- endfor -%}
        {%- endfor -%}
      };

      /* URL des 4 images BLANCHES de repli (patch-{forme}-blanc.png). Ces images
         EXISTENT déjà ; elles sont teintées en CSS/canvas avec la couleur choisie
         quand la vraie image colorée n'a pas encore été fournie. */
      window.PATCH_WHITE_URLS = {
        rond:      "{{ 'patch-rond-blanc.png'      | asset_url }}",
        carre:     "{{ 'patch-carre-blanc.png'     | asset_url }}",
        rectangle: "{{ 'patch-rectangle-blanc.png' | asset_url }}",
        blason:    "{{ 'patch-blason-blanc.png'    | asset_url }}"
      };

      // Dictionnaire de toutes les images textile (clé = "produit-couleur-vue")
      // Généré côté Liquid pour avoir les URLs CDN exactes (avec ?v=...).
      window.PRODUCT_IMAGE_URLS = {
        {%- assign tx_products = "sweatshirt,tshirt,tshirt-polyester" | split: "," -%}
        {%- assign tx_colors = "apricot,ash,atoll,black,bottle-green,brown,burgundy,chocolate,cobalt-blue,dark-grey,diva-blue,fire-red,gold,kelly-green,millennial-lilac,millennial-mint,natural,navy,navy-blue,orange,orchid-green,orchid-pink,pacific-grey,pixel-lime,radiant-purple,red,royal-blue,sand,sky,solar-yellow,sorbet,sport-grey,stone-blue,sunset-orange,swimming-pool,urban-khaki,urban-orange,urban-purple,used-black,white" | split: "," -%}
        {%- assign tx_views = "face,dos,cote" | split: "," -%}
        {%- for p in tx_products -%}
          {%- for c in tx_colors -%}
            {%- for v in tx_views -%}
              {%- assign fname = p | append: "-" | append: c | append: "-" | append: v | append: ".png" -%}
              "{{ p }}-{{ c }}-{{ v }}": "{{ fname | asset_url }}",
            {%- endfor -%}
          {%- endfor -%}
        {%- endfor -%}
      };

      window.COIN_IMAGE_URLS = {
        'patch-recto-or':     "{{ 'patch-recto-or.png'     | asset_url }}",
        'patch-recto-argent': "{{ 'patch-recto-argent.png' | asset_url }}",
        'patch-recto-nickel': "{{ 'patch-recto-nickel.png' | asset_url }}",
        'patch-recto-bronze': "{{ 'patch-recto-bronze.png' | asset_url }}",
        'patch-recto-cuivre': "{{ 'patch-recto-cuivre.png' | asset_url }}",

        'patch-verso-or':     "{{ 'patch-verso-or.png'     | asset_url }}",
        'patch-verso-argent': "{{ 'patch-verso-argent.png' | asset_url }}",
        'patch-verso-nickel': "{{ 'patch-verso-nickel.png' | asset_url }}",
        'patch-verso-bronze': "{{ 'patch-verso-bronze.png' | asset_url }}",
        'patch-verso-cuivre': "{{ 'patch-verso-cuivre.png' | asset_url }}",

        'patch-cote-or':     "{{ 'patch-cote-or.png'     | asset_url }}",
        'patch-cote-argent': "{{ 'patch-cote-argent.png' | asset_url }}",
        'patch-cote-nickel': "{{ 'patch-cote-nickel.png' | asset_url }}",
        'patch-cote-bronze': "{{ 'patch-cote-bronze.png' | asset_url }}",
        'patch-cote-cuivre': "{{ 'patch-cote-cuivre.png' | asset_url }}"
      };

      // Images couleur EXISTANTES (nommées en français). Servent de repli quand
      // l'image {produit}-{slugEN}-{vue}.png n'a pas encore été fournie.
      window.PRODUCT_IMAGE_URLS_LEGACY = {
        {%- assign lg_products = "sweatshirt,tshirt,tshirt-polyester" | split: "," -%}
        {%- assign lg_colors = "blanc-casse,bleu-ciel,bleu-marine,gris,gris-ardoise,gris-fonce,jaune,marron,noir,orange,rose,rose-clair,rouge,vert-fonce,violet" | split: "," -%}
        {%- assign lg_views = "face,dos,cote" | split: "," -%}
        {%- for p in lg_products -%}
          {%- for c in lg_colors -%}
            {%- for v in lg_views -%}
              {%- assign lname = p | append: "-" | append: c | append: "-" | append: v | append: ".png" -%}
              "{{ p }}-{{ c }}-{{ v }}": "{{ lname | asset_url }}",
            {%- endfor -%}
          {%- endfor -%}
        {%- endfor -%}
      };

      // Correspondance : nouveau slug (EN) -> ancien slug d'image (FR) le plus proche.
      // Permet aux 15 images existantes de couvrir les 40 couleurs en attendant
      // que les vraies images couleur soient fournies.
      window.COLOR_SLUG_LEGACY = {
        'black': 'noir', 'used-black': 'noir',
        'white': 'blanc-casse', 'ash': 'blanc-casse', 'natural': 'blanc-casse', 'sand': 'blanc-casse',
        'navy': 'bleu-marine', 'navy-blue': 'bleu-marine', 'cobalt-blue': 'bleu-marine',
        'royal-blue': 'bleu-marine', 'urban-purple': 'bleu-marine', 'stone-blue': 'bleu-marine',
        'diva-blue': 'bleu-marine',
        'sky': 'bleu-ciel', 'atoll': 'bleu-ciel', 'swimming-pool': 'bleu-ciel',
        'millennial-mint': 'bleu-ciel', 'millennial-lilac': 'bleu-ciel',
        'red': 'rouge', 'fire-red': 'rouge', 'burgundy': 'rouge',
        'orange': 'orange', 'urban-orange': 'orange', 'sunset-orange': 'orange', 'apricot': 'orange',
        'gold': 'jaune', 'solar-yellow': 'jaune',
        'brown': 'marron', 'chocolate': 'marron',
        'bottle-green': 'vert-fonce', 'kelly-green': 'vert-fonce', 'urban-khaki': 'vert-fonce',
        'orchid-green': 'vert-fonce', 'pixel-lime': 'vert-fonce',
        'radiant-purple': 'violet',
        'orchid-pink': 'rose-clair', 'sorbet': 'rose',
        'dark-grey': 'gris-fonce', 'pacific-grey': 'gris', 'sport-grey': 'gris-ardoise'
      };

      // Images génériques (sans couleur) servant de repli si une image couleur manque
      window.PRODUCT_FALLBACK_URLS = {
        "sweatshirt": {
          face: "{{ 'sweatshirt-face.png' | asset_url }}",
          dos:  "{{ 'sweatshirt-dos.png' | asset_url }}",
          cote: "{{ 'sweatshirt-t-cote.png' | asset_url }}"
        },
        "tshirt": {
          face: "{{ 'tshirt-face.png' | asset_url }}",
          dos:  "{{ 'tshirt-dos.png' | asset_url }}",
          cote: "{{ 'tshirt-cote.png' | asset_url }}"
        },
        "tshirt-polyester": {
          face: "{{ 'tshirt-polyester-face.png' | asset_url }}",
          dos:  "{{ 'tshirt-polyester-dos.png' | asset_url }}",
          cote: "{{ 'tshirt-polyester-cote.png' | asset_url }}"
        }
      };
    </script>
    <script src="{{ 'conf-alert.js' | asset_url }}"></script>
    <script src="{{ 'conf-bgremoval2.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-product-images.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-dynamic-layout.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-drapeaux.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-patches.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-logo-drag.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-sleeve-side.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-api.js' | asset_url }}" defer></script>
    <!-- Polices Google pour l'éditeur de texte -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Bangers&family=Bebas+Neue&family=Caveat:wght@700&family=Dancing+Script:wght@700&family=Fredoka+One&family=Great+Vibes&family=Lobster&family=Luckiest+Guy&family=Merriweather:wght@700&family=Montserrat:wght@700&family=Oswald:wght@600&family=Pacifico&family=Permanent+Marker&family=Playfair+Display:wght@700&family=Poppins:wght@700&family=Righteous&family=Roboto+Slab:wght@700&family=Rock+Salt&family=Sacramento&family=Satisfy&family=Shrikhand&family=Special+Elite&family=Teko:wght@600&family=Yellowtail&display=swap" rel="stylesheet">
    <script src="{{ 'conf-text-editor.js' | asset_url }}" defer></script>
  {{ "conf-styles.css" | asset_url | stylesheet_tag }}
  </head>
  <body>
  <div class="conf-app-root">

  <!-- ══ HEADER ══ -->
  <header class="hdr">
    <div class="hdr-brand">
      <div class="hdr-icon">👕</div>
      <div>
        <div class="hdr-name">CUSTOM TEXTILE</div>
        <div class="hdr-sub">Créez votre style</div>
      </div>
    </div>

    <div class="hdr-steps">
      <div class="step on">
        <div class="step-n">1</div>
        <span class="step-lbl">Personnalisation</span>
      </div>
      <div class="step-line"></div>
      <div class="step">
        <div class="step-n">2</div>
        <span class="step-lbl">Récapitulatif</span>
      </div>
      <div class="step-line"></div>
      <div class="step">
        <div class="step-n">3</div>
        <span class="step-lbl">Commande</span>
      </div>
    </div>

    <div class="hdr-btns">
      {% comment %} <button class="obtn" onclick="shareDesign(this)">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"/></svg>
        Partager
      </button> {% endcomment %}

      <!-- Icône panier (cachée par défaut) -->
      <button class="obtn obtn-cart" id="hdr-cart-btn" style="display:none" onclick="openCartDrawer()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M7 18c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm10 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zM2.73 5.15L4 12h12.55c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1 1 0 0 0 21 3H5.21l-.94-2H1v2h2l3.6 7.59z"/>
        </svg>
        <span id="hdr-cart-count" style="
          background:#1a1a1a; color:#fff;
          border-radius:50%; font-size:10px; font-weight:700;
          width:16px; height:16px;
          display:inline-flex; align-items:center; justify-content:center;
          margin-left:2px;
        ">0</span>
      </button>

      <button class="obtn" onclick="confirmReset()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"/></svg>
        Réinitialiser
      </button>
    </div>
  </header>

  <!-- ══ TYPE BAR ══ -->
  <div class="type-bar">
    <div class="type-bar-inner">
      <div class="type-bar-label">
        <div class="type-bar-num">1.</div>
        <div>
          <div class="type-bar-title">Type de produit</div>
          <div class="type-bar-sub">Choisissez le type</div>
        </div>
      </div>
      <div class="type-bar-cards">

        <div class="pt on" data-product="sweatshirt" onclick="selProd(this)">
          <span class="pt-ck">✓</span>
          <div class="pt-ico">
            <img class="pt-img" src="{{ 'sweatshirt-face.png' | asset_url }}" alt="Sweatshirt">
          </div>
          <span>Sweatshirt</span>
        </div>

        <div class="pt" data-product="tshirt" onclick="selProd(this)">
          <span class="pt-ck">✓</span>
          <div class="pt-ico">
            <img class="pt-img" src="{{ 'tshirt-face.png' | asset_url }}" alt="T-shirt coton">
          </div>
          <span>T-shirt coton</span>
        </div>

        <div class="pt" data-product="tshirt_polyester" onclick="selProd(this)">
          <span class="pt-ck">✓</span>
          <div class="pt-ico">
            <img class="pt-img" src="{{ 'tshirt-polyester-face.png' | asset_url }}" alt="T-shirt polyester">
          </div>
          <span>T-shirt polyester</span>
        </div>

        <div class="pt" data-product="coins" onclick="selProd(this)">
          <span class="pt-ck">✓</span>
          <div class="pt-ico">
            <img class="pt-img" src="{{ 'icon-coins.png' | asset_url }}" alt="Coins">
          </div>
          <span>Coins</span>
        </div>

        <div class="pt" data-product="drapeaux" onclick="selProd(this)">
          <span class="pt-ck">✓</span>
          <div class="pt-ico">
            <img class="pt-img" src="{{ 'icon-drapeaux.png' | asset_url }}" alt="Drapeaux">
          </div>
          <span>Drapeaux</span>
        </div>

        <div class="pt" data-product="patches" onclick="selProd(this)">
          <span class="pt-ck">✓</span>
          <div class="pt-ico">
            <img class="pt-img" src="{{ 'icon-patchs.png' | asset_url }}" alt="Patchs">
          </div>
          <span>Patchs</span>
        </div>

      </div>
    </div>
  </div>

  <!-- ══ APP ══ -->
  <div class="app">

    <!-- SIDEBAR -->
    <aside class="sidebar">
      <div class="sb-inner" id="sidebar-content">

  <!-- 2. Couleur -->
        <div class="sec">
          <div class="sec-title">2. Couleur</div>
          <div class="sec-sub">Choisissez la couleur de votre article</div>
          <div class="cg">
            <div class="cs" style="background:#f5a623" title="Apricot" onclick="selColor(this,'#f5a623','Apricot')"></div>
            <div class="cs" style="background:#eff1f0;border:1.5px solid #ddd" title="Ash" onclick="selColor(this,'#eff1f0','Ash')"></div>
            <div class="cs" style="background:#3bb9e0" title="Atoll" onclick="selColor(this,'#3bb9e0','Atoll')"></div>
            <div class="cs on" style="background:#0a0a0a" title="Black" onclick="selColor(this,'#0a0a0a','Black')"></div>
            <div class="cs" style="background:#143f2e" title="Bottle Green" onclick="selColor(this,'#143f2e','Bottle Green')"></div>
            <div class="cs" style="background:#3a3130" title="Brown" onclick="selColor(this,'#3a3130','Brown')"></div>
            <div class="cs" style="background:#3d1f35" title="Burgundy" onclick="selColor(this,'#3d1f35','Burgundy')"></div>
            <div class="cs" style="background:#4a3830" title="Chocolate" onclick="selColor(this,'#4a3830','Chocolate')"></div>
            <div class="cs" style="background:#1e32e6" title="Cobalt Blue" onclick="selColor(this,'#1e32e6','Cobalt Blue')"></div>
            <div class="cs" style="background:#2e3944" title="Dark Grey" onclick="selColor(this,'#2e3944','Dark Grey')"></div>
            <div class="cs" style="background:#1e6b78" title="Diva Blue" onclick="selColor(this,'#1e6b78','Diva Blue')"></div>
            <div class="cs" style="background:#e01e1e" title="Fire Red" onclick="selColor(this,'#e01e1e','Fire Red')"></div>
            <div class="cs" style="background:#f5c518" title="Gold" onclick="selColor(this,'#f5c518','Gold')"></div>
            <div class="cs" style="background:#2fa84f" title="Kelly Green" onclick="selColor(this,'#2fa84f','Kelly Green')"></div>
