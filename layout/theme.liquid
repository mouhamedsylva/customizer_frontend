<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="canonical" href="{{ canonical_url }}">

  <title>
    {{ page_title }}
    {%- unless page_title contains shop.name %} – {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {{ content_for_header }}

  <!-- Base Reset Styles -->
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: #f5f5f5;
      color: #333;
      line-height: 1.6;
    }
    
    #MainContent {
      min-height: 100vh;
    }
  </style>

  <!-- Fabric.js -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.0/fabric.min.js"></script>

  <!-- CSS Configurateur -->
  {% if template.suffix == 'configurateur' %}
    {{ 'configurateur.css' | asset_url | stylesheet_tag }}
    {{ 'conf-sidebar.css' | asset_url | stylesheet_tag }}
    {{ 'conf-recap.css' | asset_url | stylesheet_tag }}
    {{ 'conf-canvas.css' | asset_url | stylesheet_tag }}
    {{ 'conf-canvas-single.css' | asset_url | stylesheet_tag }}
    {{ 'conf-coins.css' | asset_url | stylesheet_tag }}
  {% endif %}

  <script>document.documentElement.className = document.documentElement.className.replace('no-js','js');</script>
</head>

<body class="template-{{ template.name }}">
  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>

  {% if template.suffix == 'configurateur' %}
    <script>
      window.CONF_API_ENDPOINT = "{{ settings.api_endpoint | default: 'http://localhost:3000/api' }}";
      window.CONF_API_KEY = "{{ settings.api_key | default: '' }}";
    </script>
    <script src="{{ 'configurateur.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-canvas.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-cart.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-pricing.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-product-switch.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-recap.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-upload.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-view-switcher.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-product-images.js' | asset_url }}" defer></script>
    <script src="{{ 'conf-dynamic-layout.js' | asset_url }}" defer></script>
  {% endif %}
</body>
</html>